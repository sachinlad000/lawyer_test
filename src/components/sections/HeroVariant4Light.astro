---
/**
 * Hero Variant 4 Light: "Light Luxury"
 * Flowing elegant design, light cream background, navy text. 
 * Floating golden dust, flowing shapes, moving ribbon.
 */
---

<section id="hero-v4-light" class="hv4L" aria-labelledby="hv4L-heading">
  <div class="hv4L-bg">
    <div class="hv4L-light-beam"></div>
    <div class="hv4L-dust">
      <div class="hv4L-mote hv4L-m1"></div><div class="hv4L-mote hv4L-m2"></div>
      <div class="hv4L-mote hv4L-m3"></div><div class="hv4L-mote hv4L-m4"></div>
      <div class="hv4L-mote hv4L-m5"></div><div class="hv4L-mote hv4L-m6"></div>
    </div>
  </div>

  <div class="hv4L-content">
    <div class="hv4L-inner">
      <div class="hv4L-top-mark hv4L-anim" data-delay="0">
        <div class="hv4L-ornament">
          <span class="hv4L-orn-line"></span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="#d4af37"><path d="M12 2L15 10L24 10L17 15L19 24L12 19L5 24L7 15L0 10L9 10L12 2Z"/></svg>
          <span class="hv4L-orn-line"></span>
        </div>
        <span class="hv4L-est">Advocate Pradnya Pednekar</span>
      </div>

      <h1 id="hv4L-heading" class="hv4L-title hv4L-anim" data-delay="1">
        <span class="hv4L-title-dark">Where Law Meets</span>
        <span class="hv4L-title-gold">Uncompromising Excellence</span>
      </h1>

      <p class="hv4L-subtitle hv4L-anim" data-delay="2">
        Providing distinguished legal counsel with an unwavering dedication to protecting your rights and securing your future.
      </p>

      <div class="hv4L-cta hv4L-anim" data-delay="3">
        <a href="/contact" class="hv4L-btn-lux">
          Book Private Consultation
          <span class="hv4L-btn-glare"></span>
        </a>
      </div>
    </div>
  </div>

  <div class="hv4L-ribbon">
    <div class="hv4L-ribbon-track">
      <!-- Item -->
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> <span>Trusted Legal Advisor</span></div>
      <div class="hv4L-ribbon-sep">✧</div>
      <!-- Item -->
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <span>22+ Years of Experience</span></div>
      <div class="hv4L-ribbon-sep">✧</div>
      <!-- Item -->
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><polygon points="12 2 15 8 22 9 17 14 18 21 12 17 5 21 7 14 2 9 8 8 12 2"/></svg> <span>Results That Speak</span></div>
      <div class="hv4L-ribbon-sep">✧</div>
      <!-- Item -->
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M20 4.6a5.5 5.5 0 00-7.8 0L12 5.7l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 21.2l7.8-7.8 1-1a5.5 5.5 0 000-7.8z"/></svg> <span>Client-Centric Approach</span></div>
      
      <!-- Duplicates -->
      <div class="hv4L-ribbon-sep">✧</div>
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> <span>Trusted Legal Advisor</span></div>
      <div class="hv4L-ribbon-sep">✧</div>
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> <span>22+ Years of Experience</span></div>
      <div class="hv4L-ribbon-sep">✧</div>
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><polygon points="12 2 15 8 22 9 17 14 18 21 12 17 5 21 7 14 2 9 8 8 12 2"/></svg> <span>Results That Speak</span></div>
      <div class="hv4L-ribbon-sep">✧</div>
      <div class="hv4L-ribbon-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M20 4.6a5.5 5.5 0 00-7.8 0L12 5.7l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 21.2l7.8-7.8 1-1a5.5 5.5 0 000-7.8z"/></svg> <span>Client-Centric Approach</span></div>
    </div>
  </div>
</section>

<style>
  .hv4L {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: #fdfbf7; /* Cream */
    color: #0a2463;
    overflow: hidden;
  }

  .hv4L-bg { position: absolute; inset: 0; pointer-events: none; }
  
  .hv4L-light-beam {
    position: absolute;
    top: -50%; left: -20%;
    width: 200%; height: 200%;
    background: radial-gradient(ellipse at center, rgba(255,255,255,0.8) 0%, transparent 60%);
    animation: hv4LBeamMove 20s linear infinite alternate;
  }
  
  @keyframes hv4LBeamMove {
    to { transform: rotate(10deg); }
  }

  .hv4L-dust { position: absolute; inset:0; }
  .hv4L-mote {
    position: absolute;
    width: 4px; height: 4px;
    background: #d4af37;
    border-radius: 50%;
    filter: blur(1px);
    animation: hv4LDustFloat 10s ease-in-out infinite;
  }
  .hv4L-m1 { top:20%; left:20%; animation-delay:0s; }
  .hv4L-m2 { top:60%; left:80%; animation-delay:2s; animation-duration:12s; }
  .hv4L-m3 { top:80%; left:30%; animation-delay:4s; animation-duration:8s; }
  .hv4L-m4 { top:30%; left:70%; animation-delay:1s; animation-duration:14s; }
  .hv4L-m5 { top:50%; left:10%; animation-delay:3s; }
  .hv4L-m6 { top:10%; left:85%; animation-delay:5s; }

  @keyframes hv4LDustFloat {
    0%, 100% { transform: translateY(0); opacity:0.1; }
    50% { transform: translateY(-40px); opacity:0.5; }
  }

  .hv4L-content {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    padding: 6rem 2rem 4rem;
  }

  .hv4L-inner { max-width: 900px; text-align: center; }

  .hv4L-top-mark {
    display: flex; flex-direction: column; align-items: center; gap: 12px; margin-bottom: 2rem;
  }
  .hv4L-ornament { display: flex; align-items: center; gap: 16px; }
  .hv4L-orn-line { display: block; width: 60px; height: 1px; background: linear-gradient(90deg, transparent, #d4af37); }
  .hv4L-orn-line:last-child { background: linear-gradient(90deg, #d4af37, transparent); }
  .hv4L-est { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #b45309; }

  .hv4L-title { font-family: 'Playfair Display', Georgia, serif; line-height: 1.1; margin-bottom: 1.5rem; }
  .hv4L-title-dark { display: block; font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; color: #1e293b; margin-bottom: 10px;}
  .hv4L-title-gold {
    display: block; font-size: clamp(3rem, 7vw, 5.5rem); font-weight: 800;
    color: #d4af37;
    background: linear-gradient(135deg, #b45309 0%, #d4af37 50%, #b45309 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-size: 200%;
    animation: hv4LGold 5s linear infinite;
  }
  @keyframes hv4LGold { to { background-position: 200% center; } }

  .hv4L-subtitle {
    font-size: 1.15rem; color: #475569; max-width: 600px; margin: 0 auto 3rem; line-height: 1.6;
  }

  .hv4L-btn-lux {
    display: inline-block;
    padding: 18px 48px;
    background: #0a2463; color: #fff;
    font-weight: 700; font-size: 1.05rem;
    text-decoration: none; border-radius: 8px;
    position: relative; overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(10,36,99,0.15);
  }
  .hv4L-btn-lux:hover {
    transform: translateY(-4px); box-shadow: 0 15px 40px rgba(10,36,99,0.25); background:#0d2e82;
  }
  .hv4L-btn-glare {
    position: absolute; top:0; left:-100%; width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transform: skewX(-20deg);
    animation: hv4LGlare 3s infinite;
  }
  @keyframes hv4LGlare { 0% { left: -100%; } 50%, 100% { left: 200%; } }

  .hv4L-ribbon {
    background: #fff;
    border-top: 1px solid rgba(212,175,55,0.2);
    border-bottom: 1px solid rgba(212,175,55,0.2);
    padding: 20px 0;
    overflow: hidden;
    box-shadow: 0 -5px 15px rgba(0,0,0,0.02);
    z-index: 3;
  }
  .hv4L-ribbon-track {
    display: flex; align-items: center; gap: 32px;
    width: max-content;
    animation: hv4LScroll 25s linear infinite;
  }
  .hv4L-ribbon-item { display:flex; align-items: center; gap:12px; font-weight: 600; color: #0a2463; font-size: 1rem; }
  .hv4L-ribbon-sep { color: #d4af37; font-size: 1.2rem; margin: 0 8px; }

  @keyframes hv4LScroll { to { transform: translateX(-50%); } }

  .hv4L-anim { opacity: 0; transform: scale(0.95) translateY(20px); animation: hv4LAppear 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .hv4L-anim[data-delay="0"] { animation-delay: 0.1s; }
  .hv4L-anim[data-delay="1"] { animation-delay: 0.3s; }
  .hv4L-anim[data-delay="2"] { animation-delay: 0.5s; }
  .hv4L-anim[data-delay="3"] { animation-delay: 0.7s; }

  @keyframes hv4LAppear { to { opacity:1; transform: scale(1) translateY(0); } }

  @media(max-width:768px){
    .hv4L-content { padding: 5rem 1rem 3rem; }
    .hv4L-btn-lux { width: 100%; }
  }
</style>
