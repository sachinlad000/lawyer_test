---
/**
 * Hero Variant 5: "Futuristic / Anti-Gravity"
 * Floating UI cards, holographic accents, particle grid.
 * Features displayed as levitating cards with depth shadows.
 * Sci-fi inspired yet professional. Parallax-ready.
 */
---

<section id="hero-v5" class="hv5" aria-labelledby="hv5-heading">
  <!-- Particle grid background -->
  <canvas class="hv5-grid-canvas" aria-hidden="true"></canvas>

  <!-- Holographic light accents -->
  <div class="hv5-holo" aria-hidden="true">
    <div class="hv5-holo-ring hv5-hr-1"></div>
    <div class="hv5-holo-ring hv5-hr-2"></div>
    <div class="hv5-holo-ring hv5-hr-3"></div>
  </div>

  <!-- Content wrapper -->
  <div class="hv5-container">
    <!-- Left: Main content -->
    <div class="hv5-main">
      <div class="hv5-tag hv5-anim" data-delay="0">
        <div class="hv5-tag-glow"></div>
        <span class="hv5-tag-dot"></span>
        <span>LEGAL ADVISORY • SINCE 2002</span>
      </div>

      <h1 id="hv5-heading" class="hv5-title hv5-anim" data-delay="1">
        The Future of<br/>
        <span class="hv5-title-holo">Legal Excellence</span>
      </h1>

      <p class="hv5-desc hv5-anim" data-delay="2">
        Combining decades of legal expertise with a forward-thinking approach to deliver justice. 22+ years of results-driven practice.
      </p>

      <div class="hv5-metrics hv5-anim" data-delay="3">
        <div class="hv5-metric">
          <span class="hv5-metric-val">22+</span>
          <span class="hv5-metric-label">Years Experience</span>
        </div>
        <div class="hv5-metric-divider"></div>
        <div class="hv5-metric">
          <span class="hv5-metric-val">500+</span>
          <span class="hv5-metric-label">Cases Won</span>
        </div>
        <div class="hv5-metric-divider"></div>
        <div class="hv5-metric">
          <span class="hv5-metric-val">98%</span>
          <span class="hv5-metric-label">Success Rate</span>
        </div>
      </div>

      <div class="hv5-actions hv5-anim" data-delay="4">
        <a href="/contact" class="hv5-btn-holo">
          <span class="hv5-btn-label">Get Consultation</span>
          <span class="hv5-btn-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a href="/practice-areas" class="hv5-btn-wire">
          Contact Now
        </a>
      </div>
    </div>

    <!-- Right: Floating feature cards -->
    <div class="hv5-float-scene">
      <div class="hv5-float-card hv5-fc-1 hv5-anim" data-delay="2">
        <div class="hv5-fc-glow"></div>
        <div class="hv5-fc-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="hv5-fc-text">Trusted Legal Advisor</div>
        <div class="hv5-fc-bar"><div class="hv5-fc-bar-fill" style="width: 95%"></div></div>
      </div>

      <div class="hv5-float-card hv5-fc-2 hv5-anim" data-delay="3">
        <div class="hv5-fc-glow"></div>
        <div class="hv5-fc-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="hv5-fc-text">22+ Years of Experience</div>
        <div class="hv5-fc-bar"><div class="hv5-fc-bar-fill" style="width: 100%"></div></div>
      </div>

      <div class="hv5-float-card hv5-fc-3 hv5-anim" data-delay="4">
        <div class="hv5-fc-glow"></div>
        <div class="hv5-fc-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div class="hv5-fc-text">Results That Speak Excellence</div>
        <div class="hv5-fc-bar"><div class="hv5-fc-bar-fill" style="width: 98%"></div></div>
      </div>

      <div class="hv5-float-card hv5-fc-4 hv5-anim" data-delay="5">
        <div class="hv5-fc-glow"></div>
        <div class="hv5-fc-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
        <div class="hv5-fc-text">Client-Centric Approach</div>
        <div class="hv5-fc-bar"><div class="hv5-fc-bar-fill" style="width: 92%"></div></div>
      </div>

      <div class="hv5-float-card hv5-fc-5 hv5-anim" data-delay="6">
        <div class="hv5-fc-glow"></div>
        <div class="hv5-fc-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
        </div>
        <div class="hv5-fc-text">Committed to Legal Awareness</div>
        <div class="hv5-fc-bar"><div class="hv5-fc-bar-fill" style="width: 88%"></div></div>
      </div>

      <!-- Connection lines between cards -->
      <svg class="hv5-connections" viewBox="0 0 500 500" fill="none" aria-hidden="true">
        <line x1="250" y1="60" x2="250" y2="160" stroke="rgba(212,175,55,0.15)" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="250" y1="160" x2="250" y2="260" stroke="rgba(212,175,55,0.15)" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="250" y1="260" x2="250" y2="360" stroke="rgba(212,175,55,0.15)" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="250" y1="360" x2="250" y2="460" stroke="rgba(212,175,55,0.15)" stroke-width="1" stroke-dasharray="4 4"/>
      </svg>
    </div>
  </div>
</section>

<script>
  // Particle grid animation for canvas
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.querySelector('.hv5-grid-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let animId: number;
    const particles: { x: number; y: number; vx: number; vy: number; size: number; alpha: number }[] = [];

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function init() {
      resize();
      particles.length = 0;
      const count = Math.min(60, Math.floor((canvas.width * canvas.height) / 15000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
          size: Math.random() * 2 + 0.5,
          alpha: Math.random() * 0.3 + 0.1
        });
      }
    }

    function draw() {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Draw particles
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;

        if (p.x < 0) p.x = canvas.width;
        if (p.x > canvas.width) p.x = 0;
        if (p.y < 0) p.y = canvas.height;
        if (p.y > canvas.height) p.y = 0;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(212, 175, 55, ${p.alpha})`;
        ctx.fill();
      }

      // Draw connections
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(212, 175, 55, ${0.06 * (1 - dist / 120)})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      animId = requestAnimationFrame(draw);
    }

    // Respect reduced motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!prefersReducedMotion.matches) {
      init();
      draw();
      window.addEventListener('resize', () => { resize(); });
    }

    // Cleanup
    prefersReducedMotion.addEventListener('change', (e) => {
      if (e.matches) {
        cancelAnimationFrame(animId);
        if (ctx) ctx.clearRect(0, 0, canvas.width, canvas.height);
      } else {
        init();
        draw();
      }
    });
  });
</script>

<style>
  /* ===== VARIANT 5: FUTURISTIC / ANTI-GRAVITY ===== */
  .hv5 {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: linear-gradient(160deg, #020510 0%, #060e20 40%, #0a1830 100%);
    color: #fff;
    overflow: hidden;
    padding: 6rem 0 3rem;
  }

  /* Canvas */
  .hv5-grid-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  /* Holographic rings */
  .hv5-holo {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .hv5-holo-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid transparent;
  }

  .hv5-hr-1 {
    width: 600px;
    height: 600px;
    top: -200px;
    right: -100px;
    border-color: rgba(212, 175, 55, 0.06);
    animation: hv5RingPulse 8s ease-in-out infinite;
  }

  .hv5-hr-2 {
    width: 400px;
    height: 400px;
    bottom: -100px;
    left: -50px;
    border-color: rgba(212, 175, 55, 0.04);
    animation: hv5RingPulse 10s ease-in-out infinite 2s;
  }

  .hv5-hr-3 {
    width: 300px;
    height: 300px;
    top: 40%;
    left: 40%;
    border-color: rgba(10, 36, 99, 0.15);
    animation: hv5RingPulse 12s ease-in-out infinite 4s;
  }

  @keyframes hv5RingPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.15); opacity: 0.5; }
  }

  /* Container */
  .hv5-container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hv5-container {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  /* Tag */
  .hv5-tag {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    background: rgba(212, 175, 55, 0.06);
    border: 1px solid rgba(212, 175, 55, 0.15);
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #d4af37;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .hv5-tag-glow {
    position: absolute;
    top: 50%;
    left: -20px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(212, 175, 55, 0.3);
    filter: blur(15px);
    animation: hv5TagGlow 3s ease-in-out infinite;
  }

  @keyframes hv5TagGlow {
    0%, 100% { transform: translate(0, -50%); opacity: 0.5; }
    50% { transform: translate(calc(100% + 200px), -50%); opacity: 0; }
  }

  .hv5-tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #d4af37;
    animation: hv5DotBlink 2s ease-in-out infinite;
  }

  @keyframes hv5DotBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Title */
  .hv5-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: #fff;
  }

  .hv5-title-holo {
    display: inline-block;
    background: linear-gradient(90deg, #d4af37 0%, #fff 20%, #d4af37 40%, #f5e6a3 60%, #d4af37 80%, #fff 100%);
    background-size: 300% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: hv5HoloText 6s linear infinite;
  }

  @keyframes hv5HoloText {
    from { background-position: 0% center; }
    to { background-position: 300% center; }
  }

  /* Description */
  .hv5-desc {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    max-width: 520px;
    margin: 0 0 2rem;
  }

  /* Metrics */
  .hv5-metrics {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .hv5-metric {
    display: flex;
    flex-direction: column;
  }

  .hv5-metric-val {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: #d4af37;
    line-height: 1.2;
  }

  .hv5-metric-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hv5-metric-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Actions */
  .hv5-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hv5-btn-holo {
    display: inline-flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    border-radius: 14px;
    overflow: hidden;
    transition: all 0.3s ease;
    border: 1px solid rgba(212, 175, 55, 0.4);
    background: rgba(212, 175, 55, 0.08);
  }

  .hv5-btn-label {
    padding: 16px 24px;
    color: #d4af37;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .hv5-btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    background: rgba(212, 175, 55, 0.15);
    color: #d4af37;
    transition: all 0.3s ease;
  }

  .hv5-btn-holo:hover {
    background: rgba(212, 175, 55, 0.15);
    border-color: #d4af37;
    transform: translateY(-3px);
    box-shadow: 0 0 30px rgba(212, 175, 55, 0.2);
    color: #d4af37;
  }

  .hv5-btn-holo:hover .hv5-btn-icon {
    background: #d4af37;
    color: #050d1a;
  }

  .hv5-btn-wire {
    display: inline-flex;
    align-items: center;
    padding: 16px 28px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.7);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hv5-btn-wire:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
    transform: translateY(-3px);
  }

  /* Floating cards scene */
  .hv5-float-scene {
    position: relative;
    display: none;
    flex-direction: column;
    gap: 16px;
    perspective: 1000px;
    min-height: 520px;
  }

  @media (min-width: 1024px) {
    .hv5-float-scene { display: flex; }
  }

  .hv5-connections {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: none;
  }

  .hv5-float-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 1;
    transition: all 0.4s ease;
    cursor: default;
    transform-style: preserve-3d;
  }

  /* Staggered offsets for anti-gravity effect */
  .hv5-fc-1 { transform: translateX(0px); animation: hv5Levitate 6s ease-in-out infinite 0s; }
  .hv5-fc-2 { transform: translateX(30px); animation: hv5Levitate 6s ease-in-out infinite 0.5s; }
  .hv5-fc-3 { transform: translateX(60px); animation: hv5Levitate 6s ease-in-out infinite 1s; }
  .hv5-fc-4 { transform: translateX(30px); animation: hv5Levitate 6s ease-in-out infinite 1.5s; }
  .hv5-fc-5 { transform: translateX(0px); animation: hv5Levitate 6s ease-in-out infinite 2s; }

  @keyframes hv5Levitate {
    0%, 100% { transform: translateY(0) translateX(var(--hv5-offset, 0)); }
    50% { transform: translateY(-12px) translateX(var(--hv5-offset, 0)); }
  }

  .hv5-fc-1 { --hv5-offset: 0px; }
  .hv5-fc-2 { --hv5-offset: 30px; }
  .hv5-fc-3 { --hv5-offset: 60px; }
  .hv5-fc-4 { --hv5-offset: 30px; }
  .hv5-fc-5 { --hv5-offset: 0px; }

  .hv5-float-card:hover {
    border-color: rgba(212, 175, 55, 0.3);
    background: rgba(212, 175, 55, 0.05);
    box-shadow: 0 20px 60px rgba(212, 175, 55, 0.1);
    transform: translateY(-8px) translateX(var(--hv5-offset, 0)) scale(1.02);
  }

  .hv5-fc-glow {
    position: absolute;
    top: 50%;
    left: -10px;
    width: 4px;
    height: 30px;
    background: #d4af37;
    border-radius: 4px;
    filter: blur(3px);
    transform: translateY(-50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .hv5-float-card:hover .hv5-fc-glow {
    opacity: 1;
  }

  .hv5-fc-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212, 175, 55, 0.08);
    border-radius: 14px;
    color: #d4af37;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .hv5-float-card:hover .hv5-fc-icon {
    background: rgba(212, 175, 55, 0.15);
    transform: scale(1.1);
  }

  .hv5-fc-text {
    flex: 1;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }

  .hv5-fc-bar {
    width: 60px;
    height: 3px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .hv5-fc-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #d4af37, #f5e6a3);
    border-radius: 3px;
    transition: width 1.5s ease-out;
  }

  /* Animations */
  .hv5-anim {
    opacity: 0;
    transform: translateY(30px);
    animation: hv5Enter 0.7s ease-out forwards;
  }

  .hv5-anim[data-delay="0"] { animation-delay: 0.2s; }
  .hv5-anim[data-delay="1"] { animation-delay: 0.4s; }
  .hv5-anim[data-delay="2"] { animation-delay: 0.6s; }
  .hv5-anim[data-delay="3"] { animation-delay: 0.8s; }
  .hv5-anim[data-delay="4"] { animation-delay: 1s; }
  .hv5-anim[data-delay="5"] { animation-delay: 1.2s; }
  .hv5-anim[data-delay="6"] { animation-delay: 1.4s; }

  @keyframes hv5Enter {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .hv5 { padding: 5rem 0 3rem; }
    .hv5-container { padding: 0 1.25rem; }
    .hv5-metrics { gap: 16px; }
    .hv5-metric-val { font-size: 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv5-anim { animation: none; opacity: 1; transform: none; }
    .hv5-holo-ring, .hv5-tag-glow, .hv5-tag-dot { animation: none; }
    .hv5-float-card { animation: none; }
    .hv5-title-holo {
      animation: none;
      background-position: 0% center;
    }
  }
</style>
