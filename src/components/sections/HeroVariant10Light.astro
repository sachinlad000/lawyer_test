---
/**
 * Hero Variant 10 Light: "Bold Typography"
 * Typography-driven hero with massive expressive text.
 * Minimal visuals — the type IS the design.
 * Strong visual hierarchy, dramatic letter sizing.
 */
---

<section id="hero-v10-light" class="hv10L" aria-labelledby="hv10L-heading">
  <!-- Subtle background texture -->
  <div class="hv10L-bg" aria-hidden="true">
    <div class="hv10L-grain"></div>
    <div class="hv10L-accent-line hv10L-al-1"></div>
    <div class="hv10L-accent-line hv10L-al-2"></div>
  </div>

  <div class="hv10L-container">
    <!-- Top bar -->
    <div class="hv10L-topbar hv10L-anim" data-delay="0">
      <span class="hv10L-est">Est. 2002</span>
      <div class="hv10L-divider"></div>
      <span class="hv10L-location">Mumbai, India</span>
    </div>

    <!-- Giant headline -->
    <h1 id="hv10L-heading" class="hv10L-headline">
      <span class="hv10L-line hv10L-line-1 hv10L-anim" data-delay="1">
        <span class="hv10L-light-text">We</span>
        <span class="hv10L-heavy-text">Defend</span>
      </span>
      <span class="hv10L-line hv10L-line-2 hv10L-anim" data-delay="2">
        <span class="hv10L-heavy-text">Your</span>
        <span class="hv10L-outline-text">Rights</span>
      </span>
      <span class="hv10L-line hv10L-line-3 hv10L-anim" data-delay="3">
        <span class="hv10L-light-text">With</span>
        <span class="hv10L-gold-text">Excellence</span>
      </span>
    </h1>

    <!-- Bottom section -->
    <div class="hv10L-bottom">
      <div class="hv10L-bottom-left hv10L-anim" data-delay="4">
        <p class="hv10L-desc">
          22+ years of legal practice delivering justice, integrity, and results that
          speak for themselves.
        </p>
        <div class="hv10L-actions">
          <a href="/contact" class="hv10L-btn-primary">
            Get Consultation
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <div class="hv10L-bottom-right hv10L-anim" data-delay="4">
        <div class="hv10L-stat">
          <span class="hv10L-stat-num">22<small>+</small></span>
          <span class="hv10L-stat-label">Years</span>
        </div>
        <div class="hv10L-stat-divider"></div>
        <div class="hv10L-stat">
          <span class="hv10L-stat-num">500<small>+</small></span>
          <span class="hv10L-stat-label">Cases</span>
        </div>
        <div class="hv10L-stat-divider"></div>
        <div class="hv10L-stat">
          <span class="hv10L-stat-num">98<small>%</small></span>
          <span class="hv10L-stat-label">Success</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative vertical text -->
  <div class="hv10L-vertical" aria-hidden="true">
    <span>ADVOCATE • PRADNYA • PEDNEKAR</span>
  </div>
</section>

<style>
  .hv10L {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: #fff;
    overflow: hidden;
    padding: 6rem 2rem 4rem;
  }

  .hv10L-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hv10L-grain {
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='256' height='256' filter='url(%23n)' opacity='0.015'/%3E%3C/svg%3E");
    background-size: 256px;
  }

  .hv10L-accent-line {
    position: absolute;
    background: #d4af37;
  }

  .hv10L-al-1 {
    width: 120px; height: 4px;
    top: 30%; left: 0;
    opacity: 0.15;
  }

  .hv10L-al-2 {
    width: 4px; height: 80px;
    bottom: 20%; right: 5%;
    opacity: 0.1;
  }

  .hv10L-container {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  /* Top bar */
  .hv10L-topbar {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 3rem;
  }

  .hv10L-est, .hv10L-location {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #94a3b8;
  }

  .hv10L-divider {
    width: 40px;
    height: 1px;
    background: #d4af37;
  }

  /* Giant headline */
  .hv10L-headline {
    margin: 0 0 4rem;
    padding: 0;
  }

  .hv10L-line {
    display: flex;
    align-items: baseline;
    gap: 0.3em;
    line-height: 0.95;
    margin-bottom: 0.1em;
  }

  .hv10L-light-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.5rem, 8vw, 7rem);
    font-weight: 400;
    font-style: italic;
    color: #94a3b8;
    letter-spacing: -0.02em;
  }

  .hv10L-heavy-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 10vw, 9rem);
    font-weight: 900;
    color: #0a2463;
    letter-spacing: -0.04em;
  }

  .hv10L-outline-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 10vw, 9rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 2px #0a2463;
    transition: all 0.5s ease;
  }

  .hv10L-outline-text:hover {
    color: #0a2463;
    -webkit-text-stroke: 0;
  }

  .hv10L-gold-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 10vw, 9rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: transparent;
    background: linear-gradient(135deg, #b45309 0%, #d4af37 40%, #f59e0b 60%, #d4af37 100%);
    background-size: 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: hv10LGold 6s linear infinite;
  }

  @keyframes hv10LGold {
    to { background-position: 300% center; }
  }

  /* Bottom section */
  .hv10L-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .hv10L-bottom-left { max-width: 500px; }

  .hv10L-desc {
    font-size: 1.1rem;
    color: #64748b;
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .hv10L-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 40px;
    background: #0a2463;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(10, 36, 99, 0.15);
    position: relative;
    overflow: hidden;
  }

  .hv10L-btn-primary::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    transition: left 0.6s ease;
  }

  .hv10L-btn-primary:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 40px rgba(10, 36, 99, 0.25);
    color: #fff;
  }

  .hv10L-btn-primary:hover::after {
    left: 100%;
  }

  /* Stats */
  .hv10L-bottom-right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .hv10L-stat { text-align: center; }

  .hv10L-stat-num {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: #0a2463;
    line-height: 1;
  }

  .hv10L-stat-num small {
    font-size: 1.2rem;
    color: #d4af37;
  }

  .hv10L-stat-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #94a3b8;
    margin-top: 4px;
  }

  .hv10L-stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(10, 36, 99, 0.08);
  }

  /* Vertical text */
  .hv10L-vertical {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%) rotate(90deg);
    transform-origin: center;
    z-index: 1;
    display: none;
  }

  @media (min-width: 1280px) {
    .hv10L-vertical { display: block; }
  }

  .hv10L-vertical span {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(10, 36, 99, 0.08);
    white-space: nowrap;
  }

  /* Animation */
  .hv10L-anim {
    opacity: 0;
    transform: translateY(30px);
    animation: hv10LFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hv10L-anim[data-delay="0"] { animation-delay: 0.1s; }
  .hv10L-anim[data-delay="1"] { animation-delay: 0.25s; }
  .hv10L-anim[data-delay="2"] { animation-delay: 0.45s; }
  .hv10L-anim[data-delay="3"] { animation-delay: 0.65s; }
  .hv10L-anim[data-delay="4"] { animation-delay: 0.85s; }

  @keyframes hv10LFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hv10L { padding: 5rem 1rem 3rem; }
    .hv10L-line { flex-wrap: wrap; gap: 0 0.2em; }
    .hv10L-bottom { flex-direction: column; align-items: flex-start; }
    .hv10L-btn-primary { width: 100%; justify-content: center; }
    .hv10L-bottom-right { gap: 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv10L-anim, .hv10L-gold-text { animation: none; transform: none; opacity: 1; }
  }
</style>
