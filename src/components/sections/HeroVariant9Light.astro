---
/**
 * Hero Variant 9 Light: "Scroll-Based"
 * Progressive reveal hero with parallax-like depth layers.
 * Includes a scroll cue, subtle content reveal on scroll,
 * and lightweight CSS-driven parallax.
 */
---

<section id="hero-v9-light" class="hv9L" aria-labelledby="hv9L-heading">
  <!-- Parallax depth layers -->
  <div class="hv9L-parallax" aria-hidden="true">
    <div class="hv9L-layer hv9L-layer-1"></div>
    <div class="hv9L-layer hv9L-layer-2"></div>
    <div class="hv9L-layer hv9L-layer-3"></div>
  </div>

  <!-- Main content -->
  <div class="hv9L-content">
    <div class="hv9L-inner">
      <div class="hv9L-overline hv9L-reveal" data-reveal="0">
        <span class="hv9L-overline-dot"></span>
        Advocate Pradnya Pednekar
      </div>

      <h1 id="hv9L-heading" class="hv9L-title">
        <span class="hv9L-word hv9L-reveal" data-reveal="1">Your</span>
        <span class="hv9L-word hv9L-reveal" data-reveal="2">Legal</span>
        <span class="hv9L-word hv9L-word-accent hv9L-reveal" data-reveal="3">Champion</span>
      </h1>

      <p class="hv9L-desc hv9L-reveal" data-reveal="4">
        22+ years of delivering justice with integrity. We navigate complex legal
        landscapes so you don't have to — with expertise, empathy, and results.
      </p>

      <div class="hv9L-features hv9L-reveal" data-reveal="5">
        <div class="hv9L-feat">
          <div class="hv9L-feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="hv9L-feat-text">
            <strong>Trusted</strong>
            <span>Proven Track Record</span>
          </div>
        </div>
        <div class="hv9L-feat">
          <div class="hv9L-feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15 8 22 9 17 14 18 21 12 17 5 21 7 14 2 9 8 8 12 2"/></svg>
          </div>
          <div class="hv9L-feat-text">
            <strong>Excellence</strong>
            <span>Premium Legal Service</span>
          </div>
        </div>
        <div class="hv9L-feat">
          <div class="hv9L-feat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div class="hv9L-feat-text">
            <strong>Client-First</strong>
            <span>Your Needs, Our Priority</span>
          </div>
        </div>
      </div>

      <div class="hv9L-actions hv9L-reveal" data-reveal="6">
        <a href="/contact" class="hv9L-btn-primary">
          Book Consultation
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/practice-areas" class="hv9L-btn-outline">Our Services</a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hv9L-scroll-indicator" aria-hidden="true">
    <div class="hv9L-mouse">
      <div class="hv9L-wheel"></div>
    </div>
    <span class="hv9L-scroll-text">Scroll to explore</span>
    <div class="hv9L-scroll-arrows">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </div>
  </div>
</section>

<style>
  .hv9L {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
  }

  /* Parallax layers */
  .hv9L-parallax {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hv9L-layer {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  .hv9L-layer-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.06) 0%, transparent 70%);
    top: -10%; left: -10%;
    animation: hv9LDrift 25s ease-in-out infinite;
  }

  .hv9L-layer-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(10, 36, 99, 0.04) 0%, transparent 70%);
    bottom: -5%; right: -5%;
    animation: hv9LDrift 30s ease-in-out infinite 5s;
  }

  .hv9L-layer-3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.04) 0%, transparent 70%);
    top: 50%; left: 60%;
    animation: hv9LDrift 20s ease-in-out infinite 10s;
  }

  @keyframes hv9LDrift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }

  /* Content */
  .hv9L-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    text-align: center;
  }

  .hv9L-overline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 20px;
    background: #f8fafc;
    border: 1px solid rgba(10, 36, 99, 0.06);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0a2463;
    margin-bottom: 2.5rem;
  }

  .hv9L-overline-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #d4af37;
    animation: hv9LPulse 2s ease-in-out infinite;
  }

  @keyframes hv9LPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(1.4); }
  }

  .hv9L-title {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0 24px;
    margin: 0 0 2rem;
    line-height: 1;
  }

  .hv9L-word {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    color: #0a2463;
    display: inline-block;
  }

  .hv9L-word-accent {
    color: #d4af37;
    position: relative;
  }

  .hv9L-word-accent::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 5px;
    background: #d4af37;
    border-radius: 3px;
    animation: hv9LUnderline 1.2s cubic-bezier(0.8, 0, 0.2, 1) 1.2s forwards;
  }

  @keyframes hv9LUnderline {
    to { width: 100%; }
  }

  .hv9L-desc {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #64748b;
    line-height: 1.7;
    max-width: 620px;
    margin: 0 auto 3rem;
  }

  /* Features row */
  .hv9L-features {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .hv9L-feat {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    background: #fff;
    border: 1px solid rgba(10, 36, 99, 0.06);
    border-radius: 16px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
  }

  .hv9L-feat:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(10, 36, 99, 0.06);
    border-color: rgba(212, 175, 55, 0.2);
  }

  .hv9L-feat-icon {
    width: 42px; height: 42px;
    background: rgba(212, 175, 55, 0.08);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: #d4af37;
    flex-shrink: 0;
  }

  .hv9L-feat-icon svg { width: 20px; height: 20px; }

  .hv9L-feat-text { text-align: left; }
  .hv9L-feat-text strong { display: block; font-size: 0.9rem; color: #0a2463; }
  .hv9L-feat-text span { font-size: 0.75rem; color: #94a3b8; }

  /* Actions */
  .hv9L-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hv9L-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: #0a2463;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(10, 36, 99, 0.15);
  }

  .hv9L-btn-primary:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 40px rgba(10, 36, 99, 0.25);
    background: #0d2e82;
    color: #fff;
  }

  .hv9L-btn-outline {
    display: inline-flex;
    align-items: center;
    padding: 16px 36px;
    color: #0a2463;
    border: 2px solid rgba(10, 36, 99, 0.12);
    font-weight: 600;
    font-size: 1rem;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hv9L-btn-outline:hover {
    border-color: #0a2463;
    background: rgba(10, 36, 99, 0.03);
    transform: translateY(-4px);
    color: #0a2463;
  }

  /* Scroll indicator */
  .hv9L-scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 5;
  }

  .hv9L-mouse {
    width: 26px;
    height: 42px;
    border: 2px solid rgba(10, 36, 99, 0.15);
    border-radius: 13px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .hv9L-wheel {
    width: 4px;
    height: 8px;
    background: #d4af37;
    border-radius: 2px;
    animation: hv9LWheel 2s ease-in-out infinite;
  }

  @keyframes hv9LWheel {
    0% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(12px); }
  }

  .hv9L-scroll-text {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #94a3b8;
  }

  .hv9L-scroll-arrows {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: -4px;
    color: #cbd5e1;
  }

  .hv9L-scroll-arrows svg:first-child {
    animation: hv9LArrow 1.5s ease-in-out infinite;
  }

  .hv9L-scroll-arrows svg:last-child {
    animation: hv9LArrow 1.5s ease-in-out infinite 0.3s;
    margin-top: -8px;
  }

  @keyframes hv9LArrow {
    0%, 100% { opacity: 0.3; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(4px); }
  }

  /* Reveal animations (word by word) */
  .hv9L-reveal {
    opacity: 0;
    transform: translateY(40px);
    animation: hv9LReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hv9L-reveal[data-reveal="0"] { animation-delay: 0.1s; }
  .hv9L-reveal[data-reveal="1"] { animation-delay: 0.2s; }
  .hv9L-reveal[data-reveal="2"] { animation-delay: 0.35s; }
  .hv9L-reveal[data-reveal="3"] { animation-delay: 0.5s; }
  .hv9L-reveal[data-reveal="4"] { animation-delay: 0.7s; }
  .hv9L-reveal[data-reveal="5"] { animation-delay: 0.9s; }
  .hv9L-reveal[data-reveal="6"] { animation-delay: 1.1s; }

  @keyframes hv9LReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hv9L { padding: 5rem 1rem 5rem; }
    .hv9L-features { flex-direction: column; gap: 12px; align-items: stretch; }
    .hv9L-btn-primary, .hv9L-btn-outline { width: 100%; justify-content: center; }
    .hv9L-title { gap: 0 12px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv9L-reveal, .hv9L-wheel, .hv9L-scroll-arrows svg, .hv9L-layer, .hv9L-overline-dot, .hv9L-word-accent::after {
      animation: none; transform: none; opacity: 1; width: 100%;
    }
  }
</style>
