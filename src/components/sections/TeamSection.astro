---
/**
 * TeamSection Component
 * ====================
 * Displays team members in a responsive grid with avatar placeholders.
 * Uses theme-aware CSS variables for dark/light mode support.
 *
 * CLIENT EDITABLE: Update team member names, roles, initials, and gradient colors.
 */

const teamMembers = [
  {
    name: "Tapasya Patil",
    role: "Advocate",
    initials: "TP",
    gradient: "linear-gradient(135deg, #0a2463, #1b3a7b)",
    image: "/images/about_1.jpeg",
  },
  {
    name: "Parul Karia",
    role: "Advocate",
    initials: "PK",
    gradient: "linear-gradient(135deg, #1b3a7b, #2d4a80)",
    image: "/images/about_2.jpeg",
  },
  {
    name: "Mayur Akula",
    role: "Advocate",
    initials: "MJ",
    gradient: "linear-gradient(135deg, #d4af37, #c49a2a)",
    image: "/images/about_3.jpeg",
  },
  {
    name: "Nirmala Bhosale",
    role: "Advocate",
    initials: "AD",
    gradient: "linear-gradient(135deg, #0f1d32, #1c3263)",
    image: "/images/about_4.jpeg",
  },
  {
    name: "Ajit Kadam",
    role: "Advocate",
    initials: "AK",
    gradient: "linear-gradient(135deg, #855f24, #d4af37)",
    image: "/images/about_5.jpeg",
  },
];
---

<section class="team-section section-padding">
  <div class="container">
    <div class="section-header" data-animate="animate-fade-in-up">
      <span class="section-subtitle">Our Team</span>
      <h2 class="section-title">Meet the Professionals</h2>
      <p class="section-description">
        A dedicated team of legal professionals committed to delivering
        excellence.
      </p>
    </div>

    <div class="team-grid">
      {
        teamMembers.map((member, index) => (
          <div
            class="team-card"
            data-animate="animate-fade-in-up"
            style={`animation-delay: ${index * 100}ms;`}
          >
            <div class="team-avatar" style={`background: ${member.gradient};`}>
              {member.image ? (
                <img
                  src={member.image}
                  alt={member.name}
                  class="team-img"
                  loading="lazy"
                />
              ) : (
                <span class="team-initials">{member.initials}</span>
              )}
            </div>
            <h4 class="team-name">{member.name}</h4>
            <p class="team-role">{member.role}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Team Section */
  .team-section {
    background: var(--surface-secondary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-description {
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0.5rem auto 0;
    font-size: 1.0625rem;
  }

  /* Team Grid — responsive: 1 col → 2 col → 3–5 col */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    justify-items: center;
  }

  @media (min-width: 640px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .team-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  /* Team Card */
  .team-card {
    background: var(--surface-card);
    border: 1px solid var(--surface-card-border);
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    text-align: center;
    width: 100%;
    box-shadow: var(--card-shadow);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .team-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: var(--card-shadow-hover);
    border-color: var(--color-accent-500);
  }

  /* Avatar */
  .team-avatar {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
    border: 3px solid transparent;
    transition: border-color 0.3s ease;
    position: relative;
    overflow: visible; /* Ensure image stays within the circle */
  }

  .team-card:hover .team-avatar {
    border-color: var(--color-accent-500);
  }

  .team-initials {
    font-size: 2.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.05em;
    user-select: none;
  }

  .team-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    border-radius: 50%;
  }

  /* Name & Role */
  .team-name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.375rem;
    line-height: 1.3;
  }

  .team-role {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.4;
  }
</style>
