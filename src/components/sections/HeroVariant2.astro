---
/**
 * Hero Variant 2: "Bold Authority"
 * Split-screen layout with dramatic typography.
 * Left side: bold content block. Right side: abstract pillar/column visual.
 * Strong, commanding presence with high contrast.
 */
---

<section id="hero-v2" class="hv2" aria-labelledby="hv2-heading">
  <!-- Background pattern -->
  <div class="hv2-bg-pattern" aria-hidden="true">
    <div class="hv2-grid-lines"></div>
  </div>

  <div class="hv2-container">
    <!-- Left Content Column -->
    <div class="hv2-left">
      <div class="hv2-eyebrow hv2-anim" data-delay="0">
        <div class="hv2-eyebrow-line"></div>
        <span>EST. 2002 — LEGAL EXCELLENCE</span>
      </div>

      <h1 id="hv2-heading" class="hv2-title hv2-anim" data-delay="1">
        <span class="hv2-title-line">Justice.</span>
        <span class="hv2-title-line">Integrity.</span>
        <span class="hv2-title-line hv2-title-gold">Excellence.</span>
      </h1>

      <div class="hv2-divider hv2-anim" data-delay="2"></div>

      <ul class="hv2-features hv2-anim" data-delay="2" role="list">
        <li class="hv2-feature">
          <div class="hv2-feature-num">01</div>
          <div class="hv2-feature-text">
            <strong>Trusted Legal Advisor</strong>
            <span>Guiding clients through complex matters</span>
          </div>
        </li>
        <li class="hv2-feature">
          <div class="hv2-feature-num">02</div>
          <div class="hv2-feature-text">
            <strong>22+ Years of Experience</strong>
            <span>Proven track record of success</span>
          </div>
        </li>
        <li class="hv2-feature">
          <div class="hv2-feature-num">03</div>
          <div class="hv2-feature-text">
            <strong>Results That Speak Excellence</strong>
            <span>Delivering exceptional outcomes</span>
          </div>
        </li>
        <li class="hv2-feature">
          <div class="hv2-feature-num">04</div>
          <div class="hv2-feature-text">
            <strong>Client-Centric Approach</strong>
            <span>Your needs drive our strategy</span>
          </div>
        </li>
        <li class="hv2-feature">
          <div class="hv2-feature-num">05</div>
          <div class="hv2-feature-text">
            <strong>Committed to Legal Awareness</strong>
            <span>Empowering informed decisions</span>
          </div>
        </li>
      </ul>

      <div class="hv2-actions hv2-anim" data-delay="3">
        <a href="/contact" class="hv2-btn-primary">
          <span>Get Consultation</span>
          <div class="hv2-btn-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
        <a href="tel:+919833889863" class="hv2-btn-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          <span>Contact Now</span>
        </a>
      </div>
    </div>

    <!-- Right Visual Column -->
    <div class="hv2-right hv2-anim" data-delay="1">
      <!-- Abstract pillar columns -->
      <div class="hv2-pillars" aria-hidden="true">
        <div class="hv2-pillar hv2-pillar-1">
          <div class="hv2-pillar-glow"></div>
        </div>
        <div class="hv2-pillar hv2-pillar-2">
          <div class="hv2-pillar-glow"></div>
        </div>
        <div class="hv2-pillar hv2-pillar-3">
          <div class="hv2-pillar-glow"></div>
        </div>
      </div>

      <!-- Floating stats card -->
      <div class="hv2-stat-card hv2-float-card-1">
        <div class="hv2-stat-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <div class="hv2-stat-value">500+</div>
          <div class="hv2-stat-label">Cases Won</div>
        </div>
      </div>

      <div class="hv2-stat-card hv2-float-card-2">
        <div class="hv2-stat-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <div>
          <div class="hv2-stat-value">1000+</div>
          <div class="hv2-stat-label">Happy Clients</div>
        </div>
      </div>

      <!-- Rotating scales of justice -->
      <div class="hv2-scales">
        <svg viewBox="0 0 200 200" fill="none" class="hv2-scales-svg">
          <circle cx="100" cy="100" r="90" stroke="rgba(212,175,55,0.15)" stroke-width="1" stroke-dasharray="4 6"/>
          <circle cx="100" cy="100" r="70" stroke="rgba(212,175,55,0.1)" stroke-width="1" stroke-dasharray="2 4"/>
          <!-- Scale beam -->
          <line x1="50" y1="85" x2="150" y2="85" stroke="rgba(212,175,55,0.5)" stroke-width="2"/>
          <!-- Center post -->
          <line x1="100" y1="55" x2="100" y2="130" stroke="rgba(212,175,55,0.5)" stroke-width="2"/>
          <!-- Left pan -->
          <path d="M40 85 Q45 100 50 85" stroke="rgba(212,175,55,0.4)" stroke-width="1.5" fill="none"/>
          <line x1="50" y1="85" x2="50" y2="95" stroke="rgba(212,175,55,0.3)" stroke-width="1"/>
          <ellipse cx="50" cy="98" rx="18" ry="5" stroke="rgba(212,175,55,0.3)" stroke-width="1" fill="rgba(212,175,55,0.05)"/>
          <!-- Right pan -->
          <path d="M140 85 Q145 100 150 85" stroke="rgba(212,175,55,0.4)" stroke-width="1.5" fill="none"/>
          <line x1="150" y1="85" x2="150" y2="95" stroke="rgba(212,175,55,0.3)" stroke-width="1"/>
          <ellipse cx="150" cy="98" rx="18" ry="5" stroke="rgba(212,175,55,0.3)" stroke-width="1" fill="rgba(212,175,55,0.05)"/>
          <!-- Top triangle -->
          <polygon points="100,55 90,70 110,70" fill="rgba(212,175,55,0.15)" stroke="rgba(212,175,55,0.4)" stroke-width="1"/>
          <!-- Base -->
          <rect x="85" y="125" width="30" height="6" rx="3" fill="rgba(212,175,55,0.2)" stroke="rgba(212,175,55,0.3)" stroke-width="1"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Bottom accent line -->
  <div class="hv2-bottom-line" aria-hidden="true"></div>
</section>

<style>
  /* ===== VARIANT 2: BOLD AUTHORITY ===== */
  .hv2 {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: linear-gradient(160deg, #020817 0%, #0a1628 40%, #0d1f3c 100%);
    color: #fff;
    overflow: hidden;
    padding: 6rem 0 3rem;
  }

  /* Background grid pattern */
  .hv2-bg-pattern {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hv2-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212, 175, 55, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 175, 55, 0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    animation: hv2GridMove 30s linear infinite;
  }

  @keyframes hv2GridMove {
    0% { transform: translate(0, 0); }
    100% { transform: translate(80px, 80px); }
  }

  /* Container */
  .hv2-container {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hv2-container {
      grid-template-columns: 1.1fr 1fr;
      gap: 4rem;
    }
  }

  /* Eyebrow */
  .hv2-eyebrow {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 2rem;
  }

  .hv2-eyebrow-line {
    width: 40px;
    height: 2px;
    background: #d4af37;
    flex-shrink: 0;
  }

  .hv2-eyebrow span {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #d4af37;
  }

  /* Title */
  .hv2-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 800;
    margin: 0 0 2rem;
    line-height: 1;
  }

  .hv2-title-line {
    display: block;
    font-size: clamp(2.5rem, 6.5vw, 5.5rem);
    color: #fff;
  }

  .hv2-title-gold {
    color: #d4af37;
    text-shadow: 0 0 60px rgba(212, 175, 55, 0.3);
  }

  /* Divider */
  .hv2-divider {
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, #d4af37, transparent);
    margin-bottom: 2rem;
  }

  /* Features */
  .hv2-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hv2-feature {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 12px 16px;
    border-left: 2px solid rgba(212, 175, 55, 0.2);
    transition: all 0.3s ease;
  }

  .hv2-feature:hover {
    border-left-color: #d4af37;
    background: rgba(212, 175, 55, 0.03);
    transform: translateX(8px);
  }

  .hv2-feature-num {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #d4af37;
    opacity: 0.6;
    min-width: 24px;
    padding-top: 2px;
  }

  .hv2-feature-text strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2px;
  }

  .hv2-feature-text span {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
  }

  /* Actions */
  .hv2-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .hv2-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
    overflow: hidden;
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .hv2-btn-primary span {
    padding: 16px 24px;
    background: #d4af37;
    color: #050d1a;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .hv2-btn-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    background: #c49a2a;
    color: #050d1a;
    transition: all 0.3s ease;
  }

  .hv2-btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.4);
    color: #050d1a;
  }

  .hv2-btn-primary:hover .hv2-btn-arrow {
    background: #b8900f;
    padding-left: 20px;
    padding-right: 20px;
  }

  .hv2-btn-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  .hv2-btn-link:hover {
    color: #d4af37;
  }

  /* Right visual column */
  .hv2-right {
    position: relative;
    min-height: 500px;
    display: none;
  }

  @media (min-width: 1024px) {
    .hv2-right { display: block; }
  }

  /* Pillars */
  .hv2-pillars {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 30px;
    padding-bottom: 40px;
  }

  .hv2-pillar {
    position: relative;
    width: 60px;
    border-radius: 8px 8px 0 0;
    background: linear-gradient(180deg, rgba(212, 175, 55, 0.08) 0%, rgba(212, 175, 55, 0.02) 100%);
    border: 1px solid rgba(212, 175, 55, 0.12);
    border-bottom: none;
  }

  .hv2-pillar-1 {
    height: 280px;
    animation: hv2PillarRise 1.5s ease-out 0.5s both;
  }

  .hv2-pillar-2 {
    height: 380px;
    animation: hv2PillarRise 1.5s ease-out 0.7s both;
  }

  .hv2-pillar-3 {
    height: 320px;
    animation: hv2PillarRise 1.5s ease-out 0.9s both;
  }

  @keyframes hv2PillarRise {
    from { height: 0; opacity: 0; }
  }

  .hv2-pillar-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 60px;
    background: linear-gradient(to bottom, #d4af37, transparent);
    animation: hv2PillarGlow 3s ease-in-out infinite;
  }

  @keyframes hv2PillarGlow {
    0%, 100% { opacity: 0.3; height: 60px; }
    50% { opacity: 0.8; height: 100px; }
  }

  /* Floating stat cards */
  .hv2-stat-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    backdrop-filter: blur(20px);
    z-index: 2;
  }

  .hv2-float-card-1 {
    top: 15%;
    right: 5%;
    animation: hv2CardFloat 6s ease-in-out infinite;
  }

  .hv2-float-card-2 {
    bottom: 20%;
    left: 5%;
    animation: hv2CardFloat 6s ease-in-out infinite 2s;
  }

  @keyframes hv2CardFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  .hv2-stat-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(212, 175, 55, 0.15);
    border-radius: 12px;
    color: #d4af37;
  }

  .hv2-stat-value {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #d4af37;
    line-height: 1.2;
  }

  .hv2-stat-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Scales */
  .hv2-scales {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
  }

  .hv2-scales-svg {
    width: 100%;
    height: 100%;
    animation: hv2ScalesSpin 60s linear infinite;
  }

  @keyframes hv2ScalesSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Bottom accent */
  .hv2-bottom-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent 0%, #d4af37 50%, transparent 100%);
    z-index: 2;
  }

  /* Animations */
  .hv2-anim {
    opacity: 0;
    transform: translateX(-40px);
    animation: hv2SlideIn 0.8s ease-out forwards;
  }

  .hv2-anim[data-delay="0"] { animation-delay: 0.2s; }
  .hv2-anim[data-delay="1"] { animation-delay: 0.5s; }
  .hv2-anim[data-delay="2"] { animation-delay: 0.8s; }
  .hv2-anim[data-delay="3"] { animation-delay: 1.1s; }

  @keyframes hv2SlideIn {
    to { opacity: 1; transform: translateX(0); }
  }

  @media (max-width: 1023px) {
    .hv2 { padding: 5rem 0 3rem; }
    .hv2-container { padding: 0 1.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv2-anim { animation: none; opacity: 1; transform: none; }
    .hv2-grid-lines, .hv2-pillar, .hv2-stat-card, .hv2-scales-svg, .hv2-pillar-glow { animation: none; }
    .hv2-pillar-1 { height: 280px; opacity: 1; }
    .hv2-pillar-2 { height: 380px; opacity: 1; }
    .hv2-pillar-3 { height: 320px; opacity: 1; }
  }
</style>
