---
/**
 * Hero Variant 8 Light: "Bold Typography & Soft Accent Glow"
 * 
 * Re-imagined as a Bold Typography hero featuring a soft, pastel
 * gradient blob background with a light noise overlay. 
 * This creates a modern, sleek aesthetic while retaining maximum readability.
 */
---

<section id="hero-v8-light" class="hv8L-container" aria-labelledby="hv8L-heading">
  <!-- Accent Background -->
  <div class="hv8L-bg-wrapper" aria-hidden="true">
    <!-- Fluid animated gradient blobs -->
    <div class="hv8L-blob hv8L-blob-blue"></div>
    <div class="hv8L-blob hv8L-blob-purple"></div>
    <div class="hv8L-blob hv8L-blob-peach"></div>
    
    <!-- Grain/Noise Texture for a premium feel -->
    <div class="hv8L-noise"></div>
    
    <!-- Very soft radial white mask to ensure text area is ultra-readable -->
    <div class="hv8L-overlay-mask"></div>
  </div>

  <!-- Content -->
  <div class="hv8L-content">
    <div class="hv8L-animate" style="--anim-delay: 0.1s;">
      <span class="hv8L-eyebrow">Next-Generation Legal Counsel</span>
    </div>

    <h1 id="hv8L-heading" class="hv8L-title">
      <span class="hv8L-title-line hv8L-animate" style="--anim-delay: 0.2s;">
        Uncompromising
      </span>
      <span class="hv8L-title-line hv8L-animate" style="--anim-delay: 0.3s;">
        Legal <em class="hv8L-italic">Minds.</em>
      </span>
      <span class="hv8L-title-line hv8L-animate" style="--anim-delay: 0.4s;">
        <span class="hv8L-accent-text">Unrivaled</span> Results.
      </span>
    </h1>

    <p class="hv8L-subtitle hv8L-animate" style="--anim-delay: 0.5s;">
      Over 22 years of dedicated practice turning complex challenges into clear victories. We defend your rights with strategy and precision.
    </p>

    <div class="hv8L-actions hv8L-animate" style="--anim-delay: 0.6s;">
      <a href="/contact" class="hv8L-btn-primary">
        Schedule Consultation
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hv8L-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    min-height: 100svh;
    background-color: #fafaf9; /* Very warm light gray/white */
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
  }

  /* --- ACCENT BACKGROUND --- */
  .hv8L-bg-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hv8L-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.6;
    animation: hv8L-float 20s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    mix-blend-mode: multiply;
  }

  .hv8L-blob-blue {
    background-color: #bae6fd; /* Tailwind sky-200 */
    width: 60vw;
    height: 60vw;
    max-width: 800px;
    max-height: 800px;
    top: -20%;
    left: -10%;
    animation-duration: 25s;
  }

  .hv8L-blob-purple {
    background-color: #e9d5ff; /* Tailwind purple-200 */
    width: 50vw;
    height: 50vw;
    max-width: 600px;
    max-height: 600px;
    bottom: -10%;
    right: -10%;
    animation-duration: 22s;
    animation-delay: -5s;
    animation-direction: reverse;
  }

  .hv8L-blob-peach {
    background-color: #fed7aa; /* Tailwind orange-200 */
    width: 40vw;
    height: 40vw;
    max-width: 500px;
    max-height: 500px;
    top: 40%;
    left: 30%;
    animation-duration: 28s;
    animation-delay: -10s;
  }

  @keyframes hv8L-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(6%, 8%) scale(1.05); }
    66% { transform: translate(-3%, -5%) scale(0.95); }
  }

  .hv8L-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.15;
    mix-blend-mode: overlay;
  }

  .hv8L-overlay-mask {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(250,250,249,0.3) 0%, rgba(250,250,249,0.85) 100%);
  }
  /* ------------------------- */

  /* --- CONTENT --- */
  .hv8L-content {
    position: relative;
    z-index: 10;
    max-width: 1000px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hv8L-eyebrow {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(12px);
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #475569; /* Slate-600 */
    margin-bottom: 2.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
  }

  .hv8L-title {
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .hv8L-title-line {
    display: block;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 9vw, 6.5rem);
    font-weight: 800;
    line-height: 0.95;
    color: #0f172a; /* Slate-900 */
    letter-spacing: -0.03em;
  }

  .hv8L-italic {
    font-weight: 500;
    font-style: italic;
    color: #334155; /* Slate-700 */
    padding-right: 0.1em;
  }

  .hv8L-accent-text {
    background: linear-gradient(135deg, #1e3a8a, #3b82f6); /* dark blue to bright blue */
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    display: inline-block;
  }

  .hv8L-subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    color: #475569;
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto 3rem;
  }

  .hv8L-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 42px;
    font-size: 1.125rem;
    font-weight: 600;
    color: #ffffff;
    background: #0f172a;
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.25);
  }

  .hv8L-btn-primary:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 35px -10px rgba(15, 23, 42, 0.35);
    background: #1e293b;
  }

  /* --- ANIMATIONS --- */
  .hv8L-animate {
    opacity: 0;
    transform: translateY(30px) scale(0.98);
    animation: hv8LFadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--anim-delay, 0s);
  }

  @keyframes hv8LFadeUp {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv8L-animate { animation: none; opacity: 1; transform: none; }
    .hv8L-blob { animation: none; }
  }
</style>
