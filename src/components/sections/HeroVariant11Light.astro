---
/**
 * Hero Variant 11 Light: "Theme-Aware Light"
 * Soft off-white/cream variations with subtle gradients.
 * Warm, accessible, high contrast. Feels organic and inviting.
 * layered card design with gentle gradient backgrounds.
 */
---

<section id="hero-v11-light" class="hv11L" aria-labelledby="hv11L-heading">
  <!-- Layered gradient background -->
  <div class="hv11L-bg" aria-hidden="true">
    <div class="hv11L-gradient-1"></div>
    <div class="hv11L-gradient-2"></div>
    <div class="hv11L-gradient-3"></div>
    <!-- Subtle wave divider at bottom -->
    <svg class="hv11L-wave" viewBox="0 0 1440 120" preserveAspectRatio="none">
      <path d="M0,60 C360,120 720,0 1080,60 C1260,90 1380,48 1440,60 L1440,120 L0,120 Z" fill="#ffffff" opacity="0.6"/>
      <path d="M0,80 C360,20 720,100 1080,60 C1260,40 1380,80 1440,70 L1440,120 L0,120 Z" fill="#ffffff" opacity="0.4"/>
    </svg>
  </div>

  <div class="hv11L-container">
    <!-- Main card -->
    <div class="hv11L-card">
      <div class="hv11L-card-inner">
        <!-- Left content -->
        <div class="hv11L-left">
          <div class="hv11L-eyebrow hv11L-anim" data-delay="0">
            <div class="hv11L-eyebrow-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <span>Trusted Legal Excellence</span>
          </div>

          <h1 id="hv11L-heading" class="hv11L-title hv11L-anim" data-delay="1">
            Compassionate<br/>
            <span class="hv11L-title-warm">Legal Counsel</span>
          </h1>

          <p class="hv11L-desc hv11L-anim" data-delay="2">
            Every legal journey is personal. With 22+ years of experience, Advocate
            Pradnya Pednekar brings warmth, expertise, and unwavering dedication to
            protect what matters most to you.
          </p>

          <!-- Key points -->
          <div class="hv11L-points hv11L-anim" data-delay="3">
            <div class="hv11L-point">
              <div class="hv11L-check">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Bar Council Registered Professional</span>
            </div>
            <div class="hv11L-point">
              <div class="hv11L-check">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>22+ Years of Proven Experience</span>
            </div>
            <div class="hv11L-point">
              <div class="hv11L-check">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span>Client-Centric Approach</span>
            </div>
          </div>

          <div class="hv11L-actions hv11L-anim" data-delay="4">
            <a href="/contact" class="hv11L-btn-warm">
              Schedule Consultation
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/practice-areas" class="hv11L-btn-soft">
              Practice Areas
            </a>
          </div>
        </div>

        <!-- Right visual -->
        <div class="hv11L-right hv11L-anim" data-delay="2">
          <div class="hv11L-visual-stack">
            <!-- Stacked info cards -->
            <div class="hv11L-info-card hv11L-ic-1">
              <div class="hv11L-ic-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <strong>22+ Years</strong>
                <span>of Legal Excellence</span>
              </div>
            </div>

            <div class="hv11L-info-card hv11L-ic-2">
              <div class="hv11L-ic-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <strong>Trusted Advisor</strong>
                <span>Protecting Your Rights</span>
              </div>
            </div>

            <div class="hv11L-info-card hv11L-ic-3">
              <div class="hv11L-ic-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15 8 22 9 17 14 18 21 12 17 5 21 7 14 2 9 8 8 12 2"/></svg>
              </div>
              <div>
                <strong>98% Success</strong>
                <span>Client Satisfaction</span>
              </div>
            </div>

            <!-- Central decorative element -->
            <div class="hv11L-center-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom testimonial snippet -->
    <div class="hv11L-testimonial hv11L-anim" data-delay="5">
      <div class="hv11L-testimonial-quote">"</div>
      <p>"Advocate Pednekar's empathetic approach and legal expertise gave us confidence during our most challenging times."</p>
      <span class="hv11L-testimonial-author">— A Grateful Client</span>
    </div>
  </div>
</section>

<style>
  .hv11L {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
    background: #fffbf0; /* Warm off-white */
  }

  /* Layered gradients */
  .hv11L-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hv11L-gradient-1 {
    position: absolute;
    width: 800px; height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.08) 0%, transparent 60%);
    top: -200px; left: -200px;
    filter: blur(60px);
    animation: hv11LPulse 20s ease-in-out infinite;
  }

  .hv11L-gradient-2 {
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(251, 191, 36, 0.06) 0%, transparent 60%);
    bottom: -100px; right: -100px;
    filter: blur(60px);
    animation: hv11LPulse 25s ease-in-out infinite 3s;
  }

  .hv11L-gradient-3 {
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(10, 36, 99, 0.03) 0%, transparent 60%);
    top: 50%; left: 50%;
    filter: blur(60px);
    animation: hv11LPulse 18s ease-in-out infinite 6s;
  }

  @keyframes hv11LPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .hv11L-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 120px;
  }

  .hv11L-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  /* Main card */
  .hv11L-card {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 32px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.04),
      0 0 0 1px rgba(255, 255, 255, 0.5) inset;
    overflow: hidden;
  }

  .hv11L-card-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 3rem 2.5rem;
  }

  @media (min-width: 1024px) {
    .hv11L-card-inner { grid-template-columns: 1.3fr 1fr; gap: 4rem; padding: 4rem; }
  }

  /* Left content */
  .hv11L-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 2rem;
  }

  .hv11L-eyebrow-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.15), rgba(212, 175, 55, 0.05));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #b45309;
  }

  .hv11L-eyebrow-icon svg { width: 18px; height: 18px; }

  .hv11L-eyebrow span {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #92400e;
  }

  .hv11L-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: #1e293b;
    margin: 0 0 1.5rem;
  }

  .hv11L-title-warm {
    color: #b45309;
    position: relative;
  }

  .hv11L-title-warm::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 4px;
    background: linear-gradient(90deg, #d4af37, #f59e0b);
    border-radius: 2px;
    animation: hv11LGrow 1.5s cubic-bezier(0.8, 0, 0.2, 1) 0.8s forwards;
  }

  @keyframes hv11LGrow {
    to { width: 100%; }
  }

  .hv11L-desc {
    font-size: 1.05rem;
    color: #64748b;
    line-height: 1.7;
    margin: 0 0 2rem;
    max-width: 520px;
  }

  /* Key points */
  .hv11L-points {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 2.5rem;
  }

  .hv11L-point {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hv11L-check {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, #ecfdf5, #d1fae5);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #059669;
    flex-shrink: 0;
  }

  .hv11L-point span {
    font-size: 0.95rem;
    font-weight: 600;
    color: #334155;
  }

  /* Actions */
  .hv11L-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hv11L-btn-warm {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background: linear-gradient(135deg, #92400e 0%, #b45309 100%);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px rgba(146, 64, 14, 0.15);
  }

  .hv11L-btn-warm:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 40px rgba(146, 64, 14, 0.25);
    color: #fff;
  }

  .hv11L-btn-soft {
    display: inline-flex;
    align-items: center;
    padding: 16px 32px;
    color: #92400e;
    font-weight: 600;
    font-size: 1rem;
    border: 2px solid rgba(146, 64, 14, 0.15);
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hv11L-btn-soft:hover {
    border-color: #b45309;
    background: rgba(146, 64, 14, 0.03);
    transform: translateY(-4px);
    color: #92400e;
  }

  /* Right visual stack */
  .hv11L-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hv11L-visual-stack {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: 350px;
  }

  .hv11L-info-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    background: #fff;
    border: 1px solid rgba(212, 175, 55, 0.1);
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    will-change: transform;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .hv11L-info-card:hover {
    transform: scale(1.05) !important;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
    z-index: 10;
  }

  .hv11L-info-card strong { display: block; font-size: 0.95rem; color: #1e293b; }
  .hv11L-info-card span { font-size: 0.75rem; color: #94a3b8; }

  .hv11L-ic-icon {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.12), rgba(251, 191, 36, 0.08));
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: #b45309;
    flex-shrink: 0;
  }

  .hv11L-ic-icon svg { width: 20px; height: 20px; }

  .hv11L-ic-1 { top: 10%; left: 5%; animation: hv11LFloat 6s ease-in-out infinite; z-index: 3; }
  .hv11L-ic-2 { top: 42%; right: 0%; animation: hv11LFloat 7s ease-in-out infinite 1s; z-index: 2; }
  .hv11L-ic-3 { bottom: 10%; left: 10%; animation: hv11LFloat 5s ease-in-out infinite 2s; z-index: 1; }

  @keyframes hv11LFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .hv11L-center-badge {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 80px; height: 80px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(212, 175, 55, 0.15);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    z-index: 0;
  }

  .hv11L-center-badge svg { width: 36px; height: 36px; }

  /* Testimonial */
  .hv11L-testimonial {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 2rem;
    padding: 20px 28px;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 20px;
    backdrop-filter: blur(10px);
  }

  .hv11L-testimonial-quote {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3rem;
    line-height: 1;
    color: #d4af37;
    opacity: 0.4;
    flex-shrink: 0;
  }

  .hv11L-testimonial p {
    font-size: 0.95rem;
    color: #64748b;
    line-height: 1.5;
    font-style: italic;
    margin: 0;
    flex: 1;
  }

  .hv11L-testimonial-author {
    font-size: 0.8rem;
    font-weight: 700;
    color: #94a3b8;
    white-space: nowrap;
  }

  /* Animation */
  .hv11L-anim {
    opacity: 0;
    transform: translateY(30px);
    animation: hv11LFadeUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .hv11L-anim[data-delay="0"] { animation-delay: 0.1s; }
  .hv11L-anim[data-delay="1"] { animation-delay: 0.3s; }
  .hv11L-anim[data-delay="2"] { animation-delay: 0.5s; }
  .hv11L-anim[data-delay="3"] { animation-delay: 0.7s; }
  .hv11L-anim[data-delay="4"] { animation-delay: 0.9s; }
  .hv11L-anim[data-delay="5"] { animation-delay: 1.1s; }

  @keyframes hv11LFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1023px) {
    .hv11L-right { display: none; }
  }

  @media (max-width: 768px) {
    .hv11L { padding: 5rem 1rem 3rem; }
    .hv11L-card-inner { padding: 2rem 1.5rem; }
    .hv11L-btn-warm, .hv11L-btn-soft { width: 100%; justify-content: center; }
    .hv11L-testimonial { flex-direction: column; text-align: center; gap: 8px; }
    .hv11L-testimonial-quote { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv11L-anim, .hv11L-info-card, .hv11L-gradient-1, .hv11L-gradient-2, .hv11L-gradient-3, .hv11L-title-warm::after {
      animation: none; transform: none; opacity: 1; width: 100%;
    }
  }
</style>
