---
/**
 * Hero Variant 3 Light: "Glassmorphic Light"
 * Light background with vibrant blur blobs. Frosted white glass cards
 * with floating / tilt animations on hover.
 */
---

<section id="hero-v3-light" class="hv3L" aria-labelledby="hv3L-heading">
  <!-- Bright animated blobs -->
  <div class="hv3L-canvas" aria-hidden="true">
    <div class="hv3L-blob hv3L-blob-1"></div>
    <div class="hv3L-blob hv3L-blob-2"></div>
    <div class="hv3L-blob hv3L-blob-3"></div>
  </div>

  <div class="hv3L-wrapper">
    <div class="hv3L-main-card hv3L-anim" data-delay="0">
      <div class="hv3L-badge"><span>Excellence Since 2002</span></div>
      
      <h1 id="hv3L-heading" class="hv3L-title">
        Your Trusted<br/>
        <span class="hv3L-title-glow">Legal Advisor</span>
      </h1>
      
      <p class="hv3L-desc">
        With 22+ years of dedicated legal practice, we deliver results that speak excellence while keeping your interests at the heart of everything we do.
      </p>
      
      <div class="hv3L-actions">
        <a href="/contact" class="hv3L-btn-primary">Book Consultation</a>
        <a href="/practice-areas" class="hv3L-btn-glass">Practice Areas</a>
      </div>
    </div>

    <div class="hv3L-cards">
      <div class="hv3L-card hv3L-anim" data-delay="1">
        <div class="hv3L-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <span class="hv3L-label">Trusted Advisor</span>
      </div>
      <div class="hv3L-card hv3L-anim" data-delay="2">
        <div class="hv3L-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <span class="hv3L-label">22+ Years Expr.</span>
      </div>
      <div class="hv3L-card hv3L-anim" data-delay="3">
        <div class="hv3L-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15 8 22 9 17 14 18 21 12 17 5 21 7 14 2 9 8 8 12 2"/></svg></div>
        <span class="hv3L-label">Excellence</span>
      </div>
      <div class="hv3L-card hv3L-anim" data-delay="4">
        <div class="hv3L-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
        <span class="hv3L-label">Client-Centric</span>
      </div>
      <div class="hv3L-card hv3L-anim" data-delay="5">
        <div class="hv3L-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg></div>
        <span class="hv3L-label">Legal Awareness</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hv3L {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9; /* Light slate */
    color: #0a2463;
    overflow: hidden;
    padding: 6rem 1.5rem;
  }

  .hv3L-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hv3L-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    will-change: transform;
    opacity: 0.7;
    mix-blend-mode: multiply;
  }

  .hv3L-blob-1 {
    width: 600px; height: 600px;
    background: #dbeafe; /* Blue 100 */
    top: -10%; left: -10%;
    animation: hv3LMorph 15s infinite alternate;
  }

  .hv3L-blob-2 {
    width: 500px; height: 500px;
    background: #fef08a; /* Yellow 200 */
    top: 40%; right: -10%;
    animation: hv3LMorph 20s infinite alternate-reverse;
  }

  .hv3L-blob-3 {
    width: 400px; height: 400px;
    background: #e0e7ff; /* Indigo 100 */
    bottom: -10%; left: 30%;
    animation: hv3LMorph 18s infinite alternate 2s;
  }

  @keyframes hv3LMorph {
    0% { transform: scale(1) translate(0,0); border-radius: 50%; }
    50% { transform: scale(1.1) translate(30px, 40px); border-radius: 40% 60% 50% 50%; }
    100% { transform: scale(0.95) translate(-20px, -30px); border-radius: 60% 40% 60% 40%; }
  }

  .hv3L-wrapper {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }

  .hv3L-main-card {
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255,255,255,1);
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 32px;
    padding: 3.5rem 2.5rem;
    text-align: center;
    max-width: 760px;
    width: 100%;
    transform-style: preserve-3d;
    perspective: 1000px;
    transition: transform 0.5s ease, box-shadow 0.5s ease;
  }
  
  .hv3L-main-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.08);
  }

  .hv3L-badge {
    display: inline-block;
    padding: 8px 16px;
    background: rgba(212,175,55,0.15);
    color: #b45309;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .hv3L-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: #0a2463;
  }

  .hv3L-title-glow { color: #d4af37; }

  .hv3L-desc {
    font-size: 1.1rem;
    color: #475569;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hv3L-actions { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }

  .hv3L-btn-primary {
    padding: 16px 32px;
    background: #0a2463;
    color: white;
    font-weight: 600;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(10,36,99,0.15);
  }

  .hv3L-btn-primary:hover {
    background: #0f172a;
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(10,36,99,0.25);
  }

  .hv3L-btn-glass {
    padding: 16px 32px;
    background: rgba(255,255,255,0.8);
    color: #0a2463;
    font-weight: 600;
    border: 1px solid rgba(255,255,255,1);
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hv3L-btn-glass:hover {
    background: #fff;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }

  .hv3L-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
    width: 100%;
  }

  .hv3L-card {
    background: rgba(255,255,255,0.6);
    border: 1px solid white;
    padding: 20px 16px;
    border-radius: 20px;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
  }

  .hv3L-card:hover {
    transform: translateY(-10px) scale(1.05);
    background: #fff;
    box-shadow: 0 15px 30px rgba(0,0,0,0.08);
  }

  .hv3L-icon {
    width: 50px; height: 50px;
    background: rgba(212,175,55,0.15);
    color: #b45309;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px;
    transition: transform 0.3s ease;
  }

  .hv3L-card:hover .hv3L-icon { transform: rotate(10deg); background: rgba(212,175,55,0.25); }

  .hv3L-label { font-weight: 700; font-size: 0.9rem; color: #1e293b; }

  .hv3L-anim {
    opacity: 0;
    transform: translateY(40px);
    animation: hv3LPunch 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .hv3L-anim[data-delay="0"] { animation-delay: 0.1s; }
  .hv3L-anim[data-delay="1"] { animation-delay: 0.3s; }
  .hv3L-anim[data-delay="2"] { animation-delay: 0.4s; }
  .hv3L-anim[data-delay="3"] { animation-delay: 0.5s; }
  .hv3L-anim[data-delay="4"] { animation-delay: 0.6s; }
  .hv3L-anim[data-delay="5"] { animation-delay: 0.7s; }

  @keyframes hv3LPunch { to { opacity: 1; transform: translateY(0); } }

  @media(max-width:768px){
    .hv3L-cards { grid-template-columns: repeat(2, 1fr); }
    .hv3L-title { font-size: 2.5rem; }
  }
</style>
