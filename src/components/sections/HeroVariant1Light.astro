---
/**
 * Hero Variant 1 Light: "Minimal Elegance"
 * Clean centered layout with floating geometry & gold underline.
 * Light theme with enhanced, smooth floating animations.
 */
---

<section id="hero-v1-light" class="hv1L" aria-labelledby="hv1L-heading">
  <!-- Subtle glowing background orbs -->
  <div class="hv1L-bg" aria-hidden="true">
    <div class="hv1L-gradient-orb hv1L-orb-1"></div>
    <div class="hv1L-gradient-orb hv1L-orb-2"></div>
    <div class="hv1L-gradient-orb hv1L-orb-3"></div>
  </div>

  <!-- Floating geometric shapes -->
  <div class="hv1L-shapes" aria-hidden="true">
    <div class="hv1L-shape hv1L-shape-1">
      <svg viewBox="0 0 80 80" fill="none"><polygon points="40,5 75,65 5,65" stroke="currentColor" stroke-width="1.5" opacity="0.4"/></svg>
    </div>
    <div class="hv1L-shape hv1L-shape-2">
      <svg viewBox="0 0 60 60" fill="none"><circle cx="30" cy="30" r="28" stroke="currentColor" stroke-width="1" opacity="0.3"/></svg>
    </div>
    <div class="hv1L-shape hv1L-shape-3">
      <svg viewBox="0 0 100 100" fill="none"><rect x="10" y="10" width="80" height="80" stroke="currentColor" stroke-width="1" opacity="0.2" transform="rotate(45 50 50)"/></svg>
    </div>
  </div>

  <!-- Content -->
  <div class="hv1L-content">
    <div class="hv1L-badge hv1L-anim" data-delay="0">
      <span class="hv1L-badge-dot"></span>
      <span>Established Legal Practice</span>
    </div>

    <h1 id="hv1L-heading" class="hv1L-title hv1L-anim" data-delay="1">
      Trusted Legal<br/>
      <span class="hv1L-title-accent">Advisor</span>
    </h1>

    <p class="hv1L-subtitle hv1L-anim" data-delay="2">
      22+ Years of unwavering commitment to legal excellence. Providing expert counsel with integrity.
    </p>

    <!-- Moving features ticker for more animation -->
    <div class="hv1L-features-wrapper hv1L-anim" data-delay="3">
      <div class="hv1L-features-track">
        <ul class="hv1L-features" role="list">
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Trusted Legal Advisor</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> 22+ Years of Experience</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Results That Speak Excellence</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Client-Centric Approach</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Committed to Legal Awareness</li>
        </ul>
        <ul class="hv1L-features" aria-hidden="true" role="list">
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Trusted Legal Advisor</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> 22+ Years of Experience</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Results That Speak Excellence</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Client-Centric Approach</li>
          <li class="hv1L-feature"><span class="hv1L-feature-bar"></span> Committed to Legal Awareness</li>
        </ul>
      </div>
    </div>

    <div class="hv1L-actions hv1L-anim" data-delay="4">
      <a href="/contact" class="hv1L-btn-primary">
        Get Consultation
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/practice-areas" class="hv1L-btn-outline">
        Explore Services
      </a>
    </div>
  </div>
</section>

<style>
  .hv1L {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    color: #0a2463;
    overflow: hidden;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
  }

  .hv1L-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hv1L-gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
    opacity: 0.6;
  }

  .hv1L-orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
    top: -200px;
    left: -100px;
    animation: hv1LFloat 15s ease-in-out infinite;
  }

  .hv1L-orb-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(10, 36, 99, 0.08) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    animation: hv1LFloat 18s ease-in-out infinite reverse;
  }

  .hv1L-orb-3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
    top: 40%;
    left: 60%;
    animation: hv1LFloat 20s ease-in-out infinite 2s;
  }

  @keyframes hv1LFloat {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -40px) scale(1.05); }
    66% { transform: translate(-30px, 30px) scale(0.95); }
  }

  .hv1L-shapes {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hv1L-shape {
    position: absolute;
    color: #0a2463;
    will-change: transform;
  }

  .hv1L-shape-1 {
    width: 80px;
    top: 20%;
    left: 10%;
    animation: hv1LShapeAnim 8s ease-in-out infinite;
  }

  .hv1L-shape-2 {
    width: 60px;
    top: 30%;
    right: 15%;
    animation: hv1LShapeAnim 12s ease-in-out infinite 2s;
  }

  .hv1L-shape-3 {
    width: 120px;
    bottom: 15%;
    left: 20%;
    animation: hv1LShapeAnim 14s ease-in-out infinite 4s;
    color: #d4af37;
  }

  @keyframes hv1LShapeAnim {
    0%, 100% { transform: translateY(0) rotate(0deg) scale(1); }
    50% { transform: translateY(-30px) rotate(15deg) scale(1.1); }
  }

  .hv1L-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }

  .hv1L-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    background: #f8fafc;
    border: 1px solid rgba(10, 36, 99, 0.1);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a2463;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hv1L-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  .hv1L-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #d4af37;
    animation: hv1LPulse 2s ease-in-out infinite;
  }

  @keyframes hv1LPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(1.3); }
  }

  .hv1L-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: #0a2463;
  }

  .hv1L-title-accent {
    color: #d4af37;
    position: relative;
    display: inline-block;
  }

  .hv1L-title-accent::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 4px;
    background: #d4af37;
    animation: hv1LUnderline 1.2s cubic-bezier(0.8, 0, 0.2, 1) 1s forwards;
  }

  @keyframes hv1LUnderline {
    to { width: 100%; }
  }

  .hv1L-subtitle {
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    color: #4b5563;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    max-width: 650px;
  }

  .hv1L-features-wrapper {
    overflow: hidden;
    margin: 0 auto 3rem;
    position: relative;
    width: 100%;
    max-width: 800px;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .hv1L-features-track {
    display: flex;
    width: max-content;
    animation: hv1LScrollTrack 25s linear infinite;
    will-change: transform;
  }

  .hv1L-features-track:hover {
    animation-play-state: paused;
  }

  @keyframes hv1LScrollTrack {
    to { transform: translateX(-50%); }
  }

  .hv1L-features {
    display: flex;
    gap: 24px;
    list-style: none;
    padding: 0 12px;
    margin: 0;
  }

  .hv1L-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    color: #0a2463;
    padding: 10px 20px;
    background: #fff;
    border: 1px solid rgba(10, 36, 99, 0.08);
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    white-space: nowrap;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .hv1L-feature:hover {
    transform: translateY(-3px);
    border-color: #d4af37;
  }

  .hv1L-feature-bar {
    width: 4px;
    height: 16px;
    background: #d4af37;
    border-radius: 2px;
  }

  .hv1L-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hv1L-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: #0a2463;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 25px rgba(10, 36, 99, 0.2);
  }

  .hv1L-btn-primary:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 15px 35px rgba(10, 36, 99, 0.3);
    background: #0d2e82;
  }

  .hv1L-btn-outline {
    display: inline-flex;
    align-items: center;
    padding: 16px 36px;
    color: #0a2463;
    font-weight: 600;
    font-size: 1rem;
    border: 2px solid #0a2463;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hv1L-btn-outline:hover {
    background: rgba(10, 36, 99, 0.05);
    transform: translateY(-4px);
  }

  .hv1L-anim {
    opacity: 0;
    transform: translateY(30px);
    animation: hv1LFadeUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .hv1L-anim[data-delay="0"] { animation-delay: 0.1s; }
  .hv1L-anim[data-delay="1"] { animation-delay: 0.3s; }
  .hv1L-anim[data-delay="2"] { animation-delay: 0.5s; }
  .hv1L-anim[data-delay="3"] { animation-delay: 0.7s; }
  .hv1L-anim[data-delay="4"] { animation-delay: 0.9s; }

  @keyframes hv1LFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hv1L { padding: 5rem 1rem 3rem; }
    .hv1L-btn-primary, .hv1L-btn-outline { width: 100%; justify-content: center; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hv1L-anim, .hv1L-title-accent::after, .hv1L-gradient-orb, .hv1L-shape, .hv1L-features-track { animation: none; transform: none; opacity: 1; width: 100%; }
  }
</style>
