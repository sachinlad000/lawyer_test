---
/**
 * Hero Variant 4: "Dark Luxury"
 * Rich dark theme with premium gold accents, textured background.
 * Full-bleed hero with cinematic feel. Horizontal scrolling feature ribbon.
 * Large dramatic headline with gold gradient text.
 */
---

<section id="hero-v4" class="hv4" aria-labelledby="hv4-heading">
  <!-- Cinematic background layers -->
  <div class="hv4-bg" aria-hidden="true">
    <div class="hv4-vignette"></div>
    <div class="hv4-gold-streaks">
      <div class="hv4-streak hv4-streak-1"></div>
      <div class="hv4-streak hv4-streak-2"></div>
      <div class="hv4-streak hv4-streak-3"></div>
    </div>
    <div class="hv4-particles">
      <div class="hv4-particle hv4-p1"></div>
      <div class="hv4-particle hv4-p2"></div>
      <div class="hv4-particle hv4-p3"></div>
      <div class="hv4-particle hv4-p4"></div>
      <div class="hv4-particle hv4-p5"></div>
      <div class="hv4-particle hv4-p6"></div>
      <div class="hv4-particle hv4-p7"></div>
      <div class="hv4-particle hv4-p8"></div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="hv4-content">
    <div class="hv4-inner">
      <!-- Decorative top line -->
      <div class="hv4-top-mark hv4-anim" data-delay="0">
        <div class="hv4-ornament">
          <span class="hv4-orn-line"></span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#d4af37"><polygon points="12,2 15,10 24,10 17,15 19,24 12,19 5,24 7,15 0,10 9,10"/></svg>
          <span class="hv4-orn-line"></span>
        </div>
        <span class="hv4-est">Advocate Pradnya Pednekar</span>
      </div>

      <h1 id="hv4-heading" class="hv4-title hv4-anim" data-delay="1">
        <span class="hv4-title-white">Where Law Meets</span>
        <span class="hv4-title-gradient">Uncompromising Excellence</span>
      </h1>

      <p class="hv4-subtitle hv4-anim" data-delay="2">
        Providing distinguished legal counsel with an unwavering dedication to protecting your rights and securing your future.
      </p>

      <!-- CTA Buttons -->
      <div class="hv4-cta hv4-anim" data-delay="3">
        <a href="/contact" class="hv4-btn-lux">
          <span class="hv4-btn-text">Book Private Consultation</span>
          <span class="hv4-btn-shimmer"></span>
        </a>
        <a href="/portfolio" class="hv4-btn-outline">
          View Case Portfolio
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Feature ribbon at bottom -->
  <div class="hv4-ribbon" aria-label="Key highlights">
    <div class="hv4-ribbon-track">
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>Trusted Legal Advisor</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>22+ Years of Experience</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span>Results That Speak Excellence</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span>Client-Centric Approach</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
        <span>Committed to Legal Awareness</span>
      </div>
      <!-- Duplicate for seamless scroll -->
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>Trusted Legal Advisor</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>22+ Years of Experience</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span>Results That Speak Excellence</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span>Client-Centric Approach</span>
      </div>
      <div class="hv4-ribbon-sep">◆</div>
      <div class="hv4-ribbon-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
        <span>Committed to Legal Awareness</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ===== VARIANT 4: DARK LUXURY ===== */
  .hv4 {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: #030508;
    color: #fff;
    overflow: hidden;
  }

  /* Background */
  .hv4-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 30%, rgba(10, 36, 99, 0.3) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 30% 70%, rgba(212, 175, 55, 0.05) 0%, transparent 60%);
  }

  .hv4-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(0, 0, 0, 0.6) 100%);
  }

  /* Gold light streaks */
  .hv4-gold-streaks {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hv4-streak {
    position: absolute;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
    animation: hv4Streak 8s ease-in-out infinite;
  }

  .hv4-streak-1 {
    width: 300px;
    top: 30%;
    left: -300px;
    animation-delay: 0s;
  }

  .hv4-streak-2 {
    width: 200px;
    top: 50%;
    left: -200px;
    animation-delay: 3s;
  }

  .hv4-streak-3 {
    width: 250px;
    top: 70%;
    left: -250px;
    animation-delay: 5s;
  }

  @keyframes hv4Streak {
    0% { transform: translateX(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateX(calc(100vw + 600px)); opacity: 0; }
  }

  /* Floating particles */
  .hv4-particles {
    position: absolute;
    inset: 0;
  }

  .hv4-particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: #d4af37;
    border-radius: 50%;
    animation: hv4ParticleFloat 12s ease-in-out infinite;
  }

  .hv4-p1 { top: 15%; left: 10%; animation-delay: 0s; animation-duration: 14s; }
  .hv4-p2 { top: 25%; left: 80%; animation-delay: 2s; animation-duration: 12s; }
  .hv4-p3 { top: 60%; left: 20%; animation-delay: 4s; animation-duration: 16s; }
  .hv4-p4 { top: 40%; left: 65%; animation-delay: 1s; animation-duration: 11s; }
  .hv4-p5 { top: 75%; left: 45%; animation-delay: 3s; animation-duration: 13s; }
  .hv4-p6 { top: 35%; left: 35%; animation-delay: 5s; animation-duration: 15s; width: 2px; height: 2px; }
  .hv4-p7 { top: 55%; left: 75%; animation-delay: 7s; animation-duration: 10s; width: 2px; height: 2px; }
  .hv4-p8 { top: 20%; left: 50%; animation-delay: 6s; animation-duration: 17s; width: 4px; height: 4px; opacity: 0.5; }

  @keyframes hv4ParticleFloat {
    0%, 100% { transform: translate(0, 0); opacity: 0.2; }
    25% { transform: translate(20px, -30px); opacity: 0.6; }
    50% { transform: translate(-15px, -60px); opacity: 0.3; }
    75% { transform: translate(25px, -20px); opacity: 0.7; }
  }

  /* Content area */
  .hv4-content {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    padding: 6rem 2rem 4rem;
  }

  .hv4-inner {
    max-width: 900px;
    text-align: center;
  }

  /* Top ornament */
  .hv4-top-mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 2.5rem;
  }

  .hv4-ornament {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hv4-orn-line {
    display: block;
    width: 50px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #d4af37);
  }

  .hv4-orn-line:last-child {
    background: linear-gradient(90deg, #d4af37, transparent);
  }

  .hv4-est {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(212, 175, 55, 0.7);
  }

  /* Title */
  .hv4-title {
    font-family: 'Playfair Display', Georgia, serif;
    margin: 0 0 1.5rem;
    line-height: 1.1;
  }

  .hv4-title-white {
    display: block;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0.5rem;
  }

  .hv4-title-gradient {
    display: block;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #d4af37 0%, #f5e6a3 30%, #d4af37 60%, #a37824 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: hv4GoldShimmer 4s ease-in-out infinite;
  }

  @keyframes hv4GoldShimmer {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  /* Subtitle */
  .hv4-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto 2.5rem;
  }

  /* CTA */
  .hv4-cta {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hv4-btn-lux {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 18px 36px;
    background: linear-gradient(135deg, #d4af37, #b8900f);
    color: #050d1a;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 14px;
    text-decoration: none;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow:
      0 4px 20px rgba(212, 175, 55, 0.3),
      0 0 60px rgba(212, 175, 55, 0.1);
  }

  .hv4-btn-lux:hover {
    transform: translateY(-3px);
    box-shadow:
      0 8px 30px rgba(212, 175, 55, 0.5),
      0 0 80px rgba(212, 175, 55, 0.15);
    color: #050d1a;
  }

  .hv4-btn-text {
    position: relative;
    z-index: 1;
  }

  .hv4-btn-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    animation: hv4Shimmer 3s ease-in-out infinite;
  }

  @keyframes hv4Shimmer {
    0% { left: -100%; }
    100% { left: 200%; }
  }

  .hv4-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 18px 32px;
    border: 1px solid rgba(212, 175, 55, 0.3);
    color: #d4af37;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hv4-btn-outline:hover {
    border-color: #d4af37;
    background: rgba(212, 175, 55, 0.08);
    transform: translateY(-3px);
    color: #d4af37;
  }

  /* Scrolling ribbon */
  .hv4-ribbon {
    position: relative;
    z-index: 2;
    background: rgba(212, 175, 55, 0.06);
    border-top: 1px solid rgba(212, 175, 55, 0.15);
    border-bottom: 1px solid rgba(212, 175, 55, 0.15);
    padding: 18px 0;
    overflow: hidden;
  }

  .hv4-ribbon-track {
    display: flex;
    align-items: center;
    gap: 24px;
    white-space: nowrap;
    animation: hv4Scroll 30s linear infinite;
    width: max-content;
  }

  @keyframes hv4Scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .hv4-ribbon-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    flex-shrink: 0;
  }

  .hv4-ribbon-sep {
    color: rgba(212, 175, 55, 0.3);
    font-size: 0.5rem;
    flex-shrink: 0;
  }

  /* Animations */
  .hv4-anim {
    opacity: 0;
    transform: translateY(30px);
    animation: hv4Reveal 0.9s ease-out forwards;
  }

  .hv4-anim[data-delay="0"] { animation-delay: 0.3s; }
  .hv4-anim[data-delay="1"] { animation-delay: 0.6s; }
  .hv4-anim[data-delay="2"] { animation-delay: 0.9s; }
  .hv4-anim[data-delay="3"] { animation-delay: 1.2s; }

  @keyframes hv4Reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hv4-content { padding: 5rem 1.25rem 3rem; }
    .hv4-orn-line { width: 30px; }
    .hv4-ribbon { padding: 14px 0; }
    .hv4-ribbon-item { font-size: 0.8rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hv4-anim { animation: none; opacity: 1; transform: none; }
    .hv4-streak, .hv4-particle, .hv4-btn-shimmer, .hv4-title-gradient { animation: none; }
    .hv4-ribbon-track { animation: none; }
    .hv4-title-gradient {
      background-position: 0% center;
    }
  }
</style>
