---
/**
 * Hero Section — Sliding Carousel
 * ================================
 * 3-slide auto-rotating carousel.
 * Uses stacked slides with CSS keyframe animations for reliable sliding.
 * Works on desktop, tablet, and mobile.
 *
 * ⏱️ To change slide timing, edit SLIDE_INTERVAL in the <script> at bottom.
 */

import {
  Phone,
  MessageCircle,
  Calendar,
  CheckCircle,
  ArrowRight,
} from "@lucide/astro";

const phone = "+91-9833889863";
const whatsapp = "919833889863";

const slides = [
  {
    badge: "Advocate in India | High Court & Supreme Court",
    headline: "Trusted Legal Excellence, Dedicated Advocacy",
    sub: "Providing expert legal representation in Civil, Criminal, and Corporate Law. Your rights. Our priority.",
    ctaText: "Book Appointment",
    ctaHref: "/contact",
    ctaIcon: "calendar",
  },
  {
    badge: "Bar Council Registered | MAH/11171/2004",
    headline: "22+ Years of Proven Legal Experience",
    sub: "Over two decades of dedicated practice across Civil, Criminal, and Corporate Law — delivering results with integrity.",
    ctaText: "Call Now",
    ctaHref: `tel:${phone.replace(/[^0-9+]/g, "")}`,
    ctaIcon: "phone",
  },
  {
    badge: "Civil • Criminal • Corporate • Family Law",
    headline: "Expert Legal Representation Across All Courts",
    sub: "From District Courts to the Supreme Court — comprehensive legal services tailored to protect your rights and interests.",
    ctaText: "View Practice Areas",
    ctaHref: "/practice-areas",
    ctaIcon: "arrow",
  },
];
---

<section class="hero-carousel" id="heroCarousel">
  <!-- Background (shared, stays fixed) -->
  <div class="hc-bg">
    <img src="/images/hero-bg.jpg" alt="" class="hc-bg-img" loading="eager" />
    <div class="hc-overlay"></div>
  </div>

  <!-- Slides wrapper -->
  <div class="hc-slides" id="hcSlides">
    {
      slides.map((s, i) => (
        <div class={`hc-slide ${i === 0 ? "hc-active" : ""}`} data-index={i}>
          <div class="hc-inner">
            <span class="hc-badge">
              <CheckCircle size={14} />
              <span>{s.badge}</span>
            </span>
            <h2 class="hc-title">{s.headline}</h2>
            <p class="hc-sub">{s.sub}</p>
            <div class="hc-buttons">
              <a href={s.ctaHref} class="hc-btn hc-btn-gold">
                {s.ctaIcon === "calendar" && <Calendar size={18} />}
                {s.ctaIcon === "phone" && <Phone size={18} />}
                {s.ctaIcon === "arrow" && <ArrowRight size={18} />}
                <span>{s.ctaText}</span>
              </a>
              <a
                href={`https://wa.me/${whatsapp}`}
                class="hc-btn hc-btn-outline"
                target="_blank"
                rel="noopener noreferrer"
              >
                <MessageCircle size={18} />
                <span>WhatsApp</span>
              </a>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Dots -->
  <div class="hc-dots" id="hcDots">
    {
      slides.map((_, i) => (
        <button
          class={`hc-dot ${i === 0 ? "hc-dot-active" : ""}`}
          data-i={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))
    }
  </div>

  <!-- Trust stats -->
  <div class="hc-trust">
    <div class="hc-trust-row">
      <div class="hc-stat">
        <strong>22+</strong><span>Years Experience</span>
      </div>
      <div class="hc-stat-sep"></div>
      <div class="hc-stat">
        <strong>1000+</strong><span>Cases Handled</span>
      </div>
      <div class="hc-stat-sep"></div>
      <div class="hc-stat"><strong>95%</strong><span>Success Rate</span></div>
      <div class="hc-stat-sep"></div>
      <div class="hc-stat"><strong>500+</strong><span>Happy Clients</span></div>
    </div>
  </div>
</section>

<style is:global>
  /* ==============================================
     HERO CAROUSEL — ALL STYLES
     ============================================== */

  .hero-carousel {
    position: relative;
    color: #fff;
    overflow: hidden;
    background: #0a2463;
  }

  /* ---------- Background ---------- */
  .hc-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hc-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hc-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 36, 99, 0.35) 0%,
      rgba(27, 58, 123, 0.25) 50%,
      rgba(10, 36, 99, 0.35) 100%
    );
  }

  /* ---------- Slides container ---------- */
  .hc-slides {
    position: relative;
    z-index: 1;
    /* Height set by the active slide */
  }

  /* ---------- Each slide ---------- */
  .hc-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* Active slide takes up space in flow */
  .hc-slide.hc-active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  /* ---------- Slide animations ---------- */
  .hc-slide.hc-enter {
    animation: hcSlideIn 0.75s ease-out forwards;
    z-index: 2;
    pointer-events: auto;
  }

  .hc-slide.hc-exit {
    animation: hcSlideOut 0.75s ease-out forwards;
    z-index: 1;
    position: relative;
  }

  @keyframes hcSlideIn {
    0% {
      opacity: 0;
      transform: translateX(60px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes hcSlideOut {
    0% {
      opacity: 1;
      transform: translateX(0);
    }
    100% {
      opacity: 0;
      transform: translateX(-60px);
    }
  }

  /* ---------- Inner content ---------- */
  .hc-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 2rem;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .hc-inner {
      padding: 3.5rem 2rem 3rem;
      max-width: 760px;
      margin: 0 auto 0 calc(max((100% - 1280px) / 2, 2rem));
    }
  }

  @media (min-width: 1024px) {
    .hc-inner {
      padding: 5rem 2rem 4rem;
    }
  }

  /* ---------- Badge ---------- */
  .hc-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 11px;
    font-weight: 500;
    margin-bottom: 16px;
    backdrop-filter: blur(4px);
    line-height: 1.4;
  }
  .hc-badge span {
    white-space: normal;
  }
  @media (min-width: 768px) {
    .hc-badge {
      font-size: 13px;
      padding: 8px 20px;
      gap: 8px;
      margin-bottom: 20px;
    }
  }

  /* ---------- Title ---------- */
  .hc-title {
    color: #fff;
    font-family: "Playfair Display", Georgia, serif;
    font-weight: 700;
    font-size: 24px;
    line-height: 1.2;
    margin: 0 0 12px;
  }
  @media (min-width: 480px) {
    .hc-title {
      font-size: 28px;
    }
  }
  @media (min-width: 768px) {
    .hc-title {
      font-size: 36px;
      margin-bottom: 16px;
    }
  }
  @media (min-width: 1024px) {
    .hc-title {
      font-size: 44px;
    }
  }

  /* ---------- Subtitle ---------- */
  .hc-sub {
    color: rgba(255, 255, 255, 0.85);
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 20px;
    max-width: 560px;
  }
  @media (min-width: 768px) {
    .hc-sub {
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 28px;
    }
  }

  /* ---------- Buttons ---------- */
  .hc-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  @media (min-width: 480px) {
    .hc-buttons {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  .hc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
    border: 2px solid transparent;
    box-sizing: border-box;
  }
  .hc-btn:hover {
    transform: translateY(-2px);
  }

  @media (min-width: 768px) {
    .hc-btn {
      padding: 14px 28px;
      font-size: 15px;
    }
  }
  @media (min-width: 1024px) {
    .hc-btn {
      padding: 16px 32px;
      font-size: 16px;
    }
  }

  .hc-btn-gold {
    background: #d4af37;
    color: #0a2463;
  }
  .hc-btn-gold:hover {
    background: #c49a2a;
    color: #0a2463;
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
  }

  .hc-btn-outline {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.35);
  }
  .hc-btn-outline:hover {
    background: #fff;
    color: #0a2463;
    border-color: #fff;
  }

  /* ---------- Dots ---------- */
  .hc-dots {
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: center;
    gap: 8px;
    padding-bottom: 18px;
  }

  .hc-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.45);
    background: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .hc-dot:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.25);
  }
  .hc-dot.hc-dot-active {
    width: 28px;
    background: #d4af37;
    border-color: #d4af37;
  }

  /* ---------- Trust bar ---------- */
  .hc-trust {
    position: relative;
    z-index: 3;
    background: rgba(0, 0, 0, 0.2);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 18px 16px;
  }
  .hc-trust-row {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px 28px;
  }
  .hc-stat {
    text-align: center;
  }
  .hc-stat strong {
    display: block;
    font-size: 22px;
    font-family: "Playfair Display", Georgia, serif;
    color: #d4af37;
    line-height: 1.2;
  }
  .hc-stat span {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.8);
  }
  .hc-stat-sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.2);
  }

  @media (min-width: 768px) {
    .hc-trust {
      padding: 22px 24px;
    }
    .hc-stat strong {
      font-size: 28px;
    }
    .hc-stat span {
      font-size: 14px;
    }
    .hc-stat-sep {
      height: 40px;
    }
    .hc-trust-row {
      gap: 18px 36px;
    }
  }

  @media (max-width: 520px) {
    .hc-stat-sep {
      display: none;
    }
    .hc-stat {
      flex: 1 1 40%;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const slides = document.querySelectorAll<HTMLElement>(".hc-slide");
    const dots = document.querySelectorAll<HTMLElement>(".hc-dot");
    if (!slides.length) return;

    let cur = 0;
    let locked = false;
    let timer: ReturnType<typeof setInterval>;

    // ⏱️ SLIDE TIMING — change this value (milliseconds)
    const SLIDE_INTERVAL = 5000;

    function go(next: number) {
      if (locked || next === cur) return;
      locked = true;

      const outSlide = slides[cur];
      const inSlide = slides[next];

      // Clear any leftover classes
      slides.forEach((s) =>
        s.classList.remove("hc-active", "hc-enter", "hc-exit"),
      );

      // Animate out
      outSlide.classList.add("hc-exit");

      // Animate in
      inSlide.classList.add("hc-enter");

      // Update dots
      dots[cur]?.classList.remove("hc-dot-active");
      dots[next]?.classList.add("hc-dot-active");

      cur = next;

      // After animation finishes, clean up
      setTimeout(() => {
        slides.forEach((s) => s.classList.remove("hc-enter", "hc-exit"));
        inSlide.classList.add("hc-active");
        locked = false;
      }, 780);
    }

    function advance() {
      go((cur + 1) % slides.length);
    }

    function startTimer() {
      timer = setInterval(advance, SLIDE_INTERVAL);
    }
    function resetTimer() {
      clearInterval(timer);
      startTimer();
    }

    // Dot clicks
    dots.forEach((d) =>
      d.addEventListener("click", () => {
        const i = Number(d.dataset.i);
        go(i);
        resetTimer();
      }),
    );

    // Pause on hover (desktop)
    const root = document.getElementById("heroCarousel");
    root?.addEventListener("mouseenter", () => clearInterval(timer));
    root?.addEventListener("mouseleave", startTimer);

    startTimer();
  });
</script>
