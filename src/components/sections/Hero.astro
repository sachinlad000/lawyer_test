---
/**
 * Law firm hero — trustworthy, authoritative, clean.
 * Content via props (defaults match common site copy; override from pages).
 */
import { ArrowRight } from "@lucide/astro";

export interface Props {
  /** [USER PROVIDED BULLET 1] */
  headline?: string;
  /** [USER PROVIDED BULLET 2] */
  subheading?: string;
  /** [USER PROVIDED BULLET 3] */
  trustPoint1?: string;
  /** [USER PROVIDED BULLET 4] */
  trustPoint2?: string;
  /** [USER PROVIDED BULLET 5] */
  trustPoint3?: string;
  /** [USER PROVIDED BULLET 6] */
  ctaLabel?: string;
  ctaHref?: string;
  /** [USER PROVIDED BULLET 7] */
  secondaryLinkLabel?: string;
  secondaryLinkHref?: string;
  /**
   * Professional hero image — pass a URL from your CMS or static import.
   * <!-- AI / asset URL: set `heroImageUrl` on <Hero /> in the page, e.g.
   *     <Hero heroImageUrl="https://your-cdn.example/hero.webp" heroImageAlt="…" /> -->
   */
  heroImageUrl?: string;
  heroImageAlt?: string;
}

const {
  headline = "Trusted Legal Advisor",
  subheading = "22+ Years of Experience",
  trustPoint1 = "Results That Speak Excellence",
  trustPoint2 = "Client-Centric Approach",
  trustPoint3 = "Committed to Legal Awareness",
  ctaLabel = "Book Appointment",
  ctaHref = "/contact",
  secondaryLinkLabel = "View Practice Areas",
  secondaryLinkHref = "/practice-areas",
  heroImageUrl = "",
  heroImageAlt = "Professional portrait representing the firm’s legal practice",
} = Astro.props;

const trustPoints = [trustPoint1, trustPoint2, trustPoint3] as const;
---

<section
  id="site-hero"
  class="hero-root relative isolate flex min-h-screen min-h-[100svh] flex-col overflow-hidden bg-[#F8FAFC] text-[#1E293B]"
  aria-labelledby="hero-heading"
>
  <div
    class="container relative z-0 flex flex-1 flex-col justify-center px-4 pb-14 pt-[calc(5.5rem+1rem)] sm:px-6 sm:pb-16 sm:pt-[calc(5.75rem+1.25rem)] lg:px-8 lg:pt-[calc(6rem+1.5rem)]"
  >
    <div
      class="grid flex-1 items-center gap-10 lg:grid-cols-2 lg:gap-12 xl:gap-16"
    >
      <!-- Column 1: copy + trust list + actions -->
      <div class="min-w-0">
        <h1
          id="hero-heading"
          class="font-[family-name:var(--font-heading)] text-[clamp(2rem,5vw,3.25rem)] font-bold leading-[1.12] tracking-tight text-[#1E293B]"
        >
          {headline}
        </h1>

        <p
          class="mt-4 max-w-xl font-[family-name:var(--font-body)] text-lg font-medium leading-relaxed text-[#1E293B]/90 sm:text-xl"
        >
          {subheading}
        </p>

        <ul class="hero-trust-list mt-8 max-w-xl space-y-3 sm:space-y-4" role="list">
          {
            trustPoints.map((text, i) => (
              <li
                class="hero-trust-item flex items-start gap-3 rounded-xl border border-[#1E293B]/10 bg-white/90 px-4 py-3 shadow-sm sm:px-5 sm:py-3.5"
                style={`--hero-i: ${i}`}
              >
                <span
                  class="mt-1 inline-flex h-2 w-2 shrink-0 rounded-full bg-[#B45309]"
                  aria-hidden="true"
                />
                <span class="font-[family-name:var(--font-body)] text-base font-medium leading-snug text-[#1E293B] sm:text-[1.0625rem]">
                  {text}
                </span>
              </li>
            ))
          }
        </ul>

        <div
          class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center"
        >
          <a
            href={ctaHref}
            class="hero-cta inline-flex w-full items-center justify-center rounded-lg bg-[#B45309] px-6 py-3.5 text-center text-base font-semibold text-white shadow-md transition hover:bg-[#92400E] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#B45309] sm:w-auto"
          >
            {ctaLabel}
          </a>
          <a
            href={secondaryLinkHref}
            class="inline-flex w-full items-center justify-center gap-2 rounded-lg border-2 border-[#1E293B]/20 bg-transparent px-5 py-3.5 text-center text-base font-semibold text-[#1E293B] transition hover:border-[#B45309] hover:text-[#B45309] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#B45309] sm:w-auto"
          >
            {secondaryLinkLabel}
            <ArrowRight class="h-5 w-5 shrink-0" aria-hidden="true" />
          </a>
        </div>
      </div>

      <!-- Column 2: image placeholder or photo (stacks below on mobile) -->
      <div class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none">
        <div
          class="relative overflow-hidden rounded-2xl border border-[#1E293B]/10 bg-white shadow-lg shadow-[#1E293B]/10 ring-1 ring-[#1E293B]/5"
        >
          {
            heroImageUrl ? (
              <img
                src={heroImageUrl}
                alt={heroImageAlt}
                width={960}
                height={1200}
                class="aspect-[4/5] w-full object-cover object-top"
                loading="eager"
                decoding="async"
              />
            ) : (
              <div
                class="flex aspect-[4/5] w-full flex-col items-center justify-center gap-2 bg-gradient-to-br from-[#F8FAFC] to-[#E2E8F0]/80 px-6 text-center"
                role="img"
                aria-label={heroImageAlt}
              >
                {/* Replace `heroImageUrl` on <Hero /> with your AI-generated or professional asset URL */}
                <span
                  class="font-[family-name:var(--font-heading)] text-lg font-semibold text-[#1E293B]/70"
                >
                  Image placeholder
                </span>
                <span
                  class="max-w-[24ch] font-[family-name:var(--font-body)] text-sm text-[#1E293B]/55"
                >
                  Pass <code class="rounded bg-[#1E293B]/10 px-1.5 py-0.5 text-xs">heroImageUrl</code> to display your
                  professional photo.
                </span>
              </div>
            )
          }
          <div
            class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#1E293B]/20 via-transparent to-transparent"
            aria-hidden="true"
          ></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes hero-trust-in {
    from {
      opacity: 0;
      transform: translateX(-1.25rem);
    }

    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .hero-trust-item {
    opacity: 0;
    animation: hero-trust-in 0.55s ease-out forwards;
    animation-delay: calc(0.12s + var(--hero-i, 0) * 0.14s);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-trust-item {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
