---
/**
 * Hero Section - Full Viewport Carousel
 *
 * 3-slide auto-rotating carousel with full 100vh height,
 * staggered content animations, Ken Burns background effect,
 * and trust stats overlay
 */

import {
  Phone,
  MessageCircle,
  Calendar,
  CheckCircle,
  ArrowRight,
} from "@lucide/astro";

const phone = "+91-9833889863";
const whatsapp = "919833889863";

const slides = [
  {
    badge: "Advocate in India | High Court & Supreme Court",
    features: [
      "Trusted Legal Advisor",
      "22+ Years of Experience",
      "Results That Speak Excellence",
      "Client-Centric Approach",
      "Committed to Legal Awareness",
    ],
    ctaText: "Book Appointment",
    ctaHref: "/contact",
    ctaIcon: "calendar",
    image: "/images/1.jpg",
  },
  // {
  //   badge: "Bar Council Registered | MAH/1117/2004",
  //   headline: "22+ Years of Proven Legal Experience",
  //   sub: "Over two decades of dedicated practice across Civil, Criminal, and Corporate Law -- delivering results with integrity.",
  //   ctaText: "Call Now",
  //   ctaHref: `tel:${phone.replace(/[^0-9+]/g, "")}`,
  //   ctaIcon: "phone",
  //   image: "/images/11.jpg",
  // },
  // {
  //   badge: "Civil - Criminal - Corporate - Family Law",
  //   headline: "Expert Legal Representation Across All Courts",
  //   sub: "From District Courts to the Supreme Court -- comprehensive legal services tailored to protect your rights and interests.",
  //   ctaText: "View Practice Areas",
  //   ctaHref: "/practice-areas",
  //   ctaIcon: "arrow",
  //   image: "/images/3.jpg",
  // },
];
---

<section class="hero-carousel" id="heroCarousel">
  <!-- Slides wrapper -->
  <div class="hc-slides" id="hcSlides">
    {
      slides.map((s, i) => (
        <div class={`hc-slide ${i === 0 ? "hc-active" : ""}`} data-index={i}>
          <div class="hc-slide-bg">
            <img
              src={s.image}
              alt=""
              class="hc-bg-img"
              loading={i === 0 ? "eager" : "lazy"}
            />
            <div class="hc-overlay" />
          </div>
          <div class="hc-inner">
            <span class="hc-badge hc-anim-item" data-anim-delay="0">
              <CheckCircle size={14} />
              <span>{s.badge}</span>
            </span>
            {s.features && (
              <ul class="hc-features">
                {s.features.map((feat: any, fi: number) => (
                  <li class="hc-feature hc-anim-item" data-anim-delay={1 + fi}>
                    <CheckCircle
                      size="1em"
                      class="hc-feature-icon"
                      color="#d4af37"
                    />
                    <span>{feat}</span>
                  </li>
                ))}
              </ul>
            )}
            <div
              class="hc-buttons hc-anim-item"
              data-anim-delay={s.features ? 1 + s.features.length : 1}
            >
              <a href={s.ctaHref} class="hc-btn hc-btn-gold">
                {s.ctaIcon === "calendar" && <Calendar size={18} />}
                {s.ctaIcon === "phone" && <Phone size={18} />}
                {s.ctaIcon === "arrow" && <ArrowRight size={18} />}
                <span>{s.ctaText}</span>
              </a>
              {/* <a
                href={`https://wa.me/${whatsapp}`}
                class="hc-btn hc-btn-gold"
                target="_blank"
                rel="noopener noreferrer"
              >
                <MessageCircle size={18} />
                <span>WhatsApp</span>
              </a> */}
            </div>
          </div>
        </div>
      ))
    }

    <!-- Dots (inside slides so absolute positioning works) -->
    <!-- <div class="hc-dots" id="hcDots">
      {
        slides.map((_, i) => (
          <button
            class={`hc-dot ${i === 0 ? "hc-dot-active" : ""}`}
            data-i={i}
            aria-label={`Slide ${i + 1}`}
          />
        ))
      }
    </div> -->
  </div>

  <!-- Trust stats — overlay at bottom of hero -->
  <!-- <div class="hc-trust">
    <div class="hc-trust-row">
      <div class="hc-stat">
        <strong>22+</strong><span>Years Experience</span>
      </div>
      <div class="hc-stat-sep"></div>
      <div class="hc-stat">
        <strong>1000+</strong><span>Cases Handled</span>
      </div>
      <div class="hc-stat-sep"></div>
      <div class="hc-stat"><strong>95%</strong><span>Success Rate</span></div>
      <div class="hc-stat-sep"></div>
      <div class="hc-stat">
        <strong>1000+</strong><span>Happy Clients</span>
      </div>
    </div>
  </div> -->
</section>

<style is:global>
  /* ==============================================
     HERO CAROUSEL - FULL VIEWPORT
     ============================================== */

  .hero-carousel {
    position: relative;
    color: #fff;
    overflow: hidden;
    background: #0a2463;
    min-height: 100vh;
    min-height: 100svh; /* accounts for mobile browser chrome */
    display: flex;
    flex-direction: column;
  }

  /* ---------- Slides wrapper — fills remaining space ---------- */
  .hc-slides {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    width: 100%;
    height: 100%;
  }

  /* ---------- Per-slide background ---------- */
  .hc-slide-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hc-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    will-change: transform;
  }

  /* Ken Burns — slow zoom on active slide */
  .hc-slide.hc-active .hc-bg-img,
  .hc-slide.hc-enter .hc-bg-img {
    animation: hcKenBurns 8s ease-out forwards;
  }

  @keyframes hcKenBurns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.08);
    }
  }

  .hc-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10, 36, 99, 0.55) 0%,
      rgba(27, 58, 123, 0.4) 50%,
      rgba(10, 36, 99, 0.55) 100%
    );
    opacity: 0;
  }

  /* ---------- Each slide ---------- */
  .hc-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    display: flex;
    align-items: center;
  }

  /* Active slide */
  .hc-slide.hc-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  /* ---------- Slide transition animations ---------- */
  .hc-slide.hc-enter {
    animation: hcSlideIn 0.75s ease-out forwards;
    z-index: 2;
    pointer-events: auto;
  }

  .hc-slide.hc-exit {
    animation: hcSlideOut 0.75s ease-out forwards;
    z-index: 1;
  }

  @keyframes hcSlideIn {
    0% {
      opacity: 0;
      transform: translateX(60px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes hcSlideOut {
    0% {
      opacity: 1;
      transform: translateX(0);
    }
    100% {
      opacity: 0;
      transform: translateX(-60px);
    }
  }

  /* ==============================================
     SLIDE CONTENT ANIMATIONS (left-to-center, staggered)
     ============================================== */

  /* Initially hidden — content will animate in */
  .hc-anim-item {
    opacity: 0;
    transform: translateX(-50px);
    will-change: transform, opacity;
  }

  /* Animate when parent slide becomes active */
  .hc-slide.hc-active .hc-anim-item,
  .hc-slide.hc-enter .hc-anim-item {
    animation: hcContentSlideRight 0.6s ease-out forwards;
  }

  /* Staggered delays */
  .hc-slide.hc-active .hc-anim-item[data-anim-delay="0"],
  .hc-slide.hc-enter .hc-anim-item[data-anim-delay="0"] {
    animation-delay: 0.1s;
  }
  .hc-slide.hc-active .hc-anim-item[data-anim-delay="1"],
  .hc-slide.hc-enter .hc-anim-item[data-anim-delay="1"] {
    animation-delay: 0.25s;
  }
  .hc-slide.hc-active .hc-anim-item[data-anim-delay="2"],
  .hc-slide.hc-enter .hc-anim-item[data-anim-delay="2"] {
    animation-delay: 0.4s;
  }
  .hc-slide.hc-active .hc-anim-item[data-anim-delay="3"],
  .hc-slide.hc-enter .hc-anim-item[data-anim-delay="3"] {
    animation-delay: 0.55s;
  }
  .hc-slide.hc-active .hc-anim-item[data-anim-delay="4"],
  .hc-slide.hc-enter .hc-anim-item[data-anim-delay="4"] {
    animation-delay: 0.7s;
  }
  .hc-slide.hc-active .hc-anim-item[data-anim-delay="5"],
  .hc-slide.hc-enter .hc-anim-item[data-anim-delay="5"] {
    animation-delay: 0.85s;
  }
  .hc-slide.hc-active .hc-anim-item[data-anim-delay="6"],
  .hc-slide.hc-enter .hc-anim-item[data-anim-delay="6"] {
    animation-delay: 1s;
  }

  @keyframes hcContentSlideRight {
    0% {
      opacity: 0;
      transform: translateX(-50px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Reset animation items when slide exits */
  .hc-slide.hc-exit .hc-anim-item {
    opacity: 1;
    transform: translateX(0);
    animation: none;
  }

  /* ---------- Inner content — vertically centered ---------- */
  .hc-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 2rem;
    padding-top: calc(80px + 2rem); /* account for fixed navbar */
    box-sizing: border-box;
    width: 100%;
  }

  @media (min-width: 768px) {
    .hc-inner {
      padding: 3.5rem 2rem 3rem;
      padding-top: calc(80px + 2.5rem);
      max-width: 760px;
      margin: 0 auto 0 calc(max((100% - 1280px) / 2, 2rem));
    }
  }

  @media (min-width: 1024px) {
    .hc-inner {
      padding: 5rem 2rem 4rem;
      padding-top: calc(80px + 3rem);
    }
  }

  /* ---------- Badge ---------- */
  .hc-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 11px;
    font-weight: 500;
    margin-bottom: 16px;
    backdrop-filter: blur(4px);
    line-height: 1.4;
  }
  .hc-badge span {
    white-space: normal;
  }
  @media (min-width: 768px) {
    .hc-badge {
      font-size: 13px;
      padding: 8px 20px;
      gap: 8px;
      margin-bottom: 20px;
    }
  }

  /* ---------- Title ---------- */
  .hc-title {
    color: #d4af37;
    font-family: "Playfair Display", Georgia, serif;
    font-weight: 700;
    font-size: 24px;
    line-height: 1.2;
    margin: 0 0 12px;
  }
  @media (min-width: 480px) {
    .hc-title {
      font-size: 28px;
    }
  }
  @media (min-width: 768px) {
    .hc-title {
      font-size: 38px;
      margin-bottom: 16px;
    }
  }
  @media (min-width: 1024px) {
    .hc-title {
      font-size: 48px;
    }
  }

  /* ---------- Features List ---------- */
  .hc-features {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hc-feature {
    display: flex;
    align-items: center;
    gap: 16px;
    color: #ffffff; /*#d4af37*/
    font-family: "Playfair Display", Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4);
  }
  .hc-feature-icon {
    flex-shrink: 0;
  }
  @media (min-width: 480px) {
    .hc-feature {
      font-size: 28px;
    }
  }
  @media (min-width: 768px) {
    .hc-feature {
      font-size: 32px;
    }
    .hc-features {
      margin-bottom: 36px;
      gap: 20px;
    }
  }

  /* ---------- Buttons ---------- */
  .hc-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  @media (min-width: 480px) {
    .hc-buttons {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  .hc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
    border: 2px solid transparent;
    box-sizing: border-box;
    will-change: transform;
  }
  .hc-btn:hover {
    transform: translateY(-3px) scale(1.02);
  }

  @media (min-width: 768px) {
    .hc-btn {
      padding: 14px 28px;
      font-size: 15px;
    }
  }
  @media (min-width: 1024px) {
    .hc-btn {
      padding: 16px 32px;
      font-size: 16px;
    }
  }

  .hc-btn-gold {
    background: #d4af37;
    color: #0a2463;
  }
  .hc-btn-gold:hover {
    background: #c49a2a;
    color: #0a2463;
    box-shadow: 0 8px 25px rgba(212, 175, 55, 0.4);
  }

  .hc-btn-outline {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.35);
  }
  .hc-btn-outline:hover {
    background: #fff;
    color: #0a2463;
    border-color: #fff;
    box-shadow: 0 8px 25px rgba(255, 255, 255, 0.2);
  }

  /* ---------- Dots ---------- */
  .hc-dots {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 5;
    display: flex;
    justify-content: center;
    gap: 8px;
    padding-bottom: 90px; /* above trust bar */
  }

  .hc-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 2px solid rgba(255, 255, 255, 0.45);
    background: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .hc-dot:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.25);
  }
  .hc-dot.hc-dot-active {
    width: 28px;
    background: #d4af37;
    border-color: #d4af37;
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.4);
  }

  /* ---------- Trust bar — overlaid at bottom of hero ---------- */
  .hc-trust {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 5;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 18px 16px;
  }
  .hc-trust-row {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px 28px;
  }
  .hc-stat {
    text-align: center;
  }
  .hc-stat strong {
    display: block;
    font-size: 22px;
    font-family: "Playfair Display", Georgia, serif;
    color: #d4af37;
    line-height: 1.2;
  }
  .hc-stat span {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.8);
  }
  .hc-stat-sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.2);
  }

  @media (min-width: 768px) {
    .hc-trust {
      padding: 22px 24px;
    }
    .hc-stat strong {
      font-size: 28px;
    }
    .hc-stat span {
      font-size: 14px;
    }
    .hc-stat-sep {
      height: 40px;
    }
    .hc-trust-row {
      gap: 18px 36px;
    }
  }

  @media (max-width: 520px) {
    .hc-stat-sep {
      display: none;
    }
    .hc-stat {
      flex: 1 1 40%;
    }
    .hc-dots {
      padding-bottom: 110px;
    }
  }

  /* ==============================================
     ACCESSIBILITY — Reduced Motion
     ============================================== */
  @media (prefers-reduced-motion: reduce) {
    .hc-slide.hc-enter,
    .hc-slide.hc-exit,
    .hc-slide.hc-active .hc-anim-item,
    .hc-slide.hc-enter .hc-anim-item,
    .hc-slide.hc-active .hc-bg-img,
    .hc-slide.hc-enter .hc-bg-img {
      animation-duration: 0.01ms !important;
      animation-delay: 0ms !important;
    }
    .hc-btn {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  function initCarousel() {
    const container = document.getElementById("hcSlides");
    const allSlides = document.querySelectorAll<HTMLElement>(".hc-slide");
    const dots = document.querySelectorAll<HTMLElement>(".hc-dot");
    if (!container || !allSlides.length) return;

    // --- Carousel state ---
    let cur = 0;
    let locked = false;
    let timer: ReturnType<typeof setInterval>;

    // SLIDE TIMING — change this value (milliseconds)
    const SLIDE_INTERVAL = 5000;

    // Reset animation items for a slide (force re-trigger)
    function resetAnimItems(slide: HTMLElement) {
      slide.querySelectorAll<HTMLElement>(".hc-anim-item").forEach((el) => {
        el.style.animation = "none";
        // Force reflow
        void el.offsetHeight;
        el.style.animation = "";
      });
    }

    // Reset Ken Burns on bg image
    function resetKenBurns(slide: HTMLElement) {
      const img = slide.querySelector<HTMLElement>(".hc-bg-img");
      if (img) {
        img.style.animation = "none";
        void img.offsetHeight;
        img.style.animation = "";
      }
    }

    function go(next: number) {
      if (locked || next === cur) return;
      locked = true;

      const outSlide = allSlides[cur];
      const inSlide = allSlides[next];

      // Clear leftover classes
      allSlides.forEach((s) =>
        s.classList.remove("hc-active", "hc-enter", "hc-exit"),
      );

      // Reset animation items on incoming slide
      resetAnimItems(inSlide);
      resetKenBurns(inSlide);

      // Animate
      outSlide.classList.add("hc-exit");
      inSlide.classList.add("hc-enter");

      // Update dots
      dots[cur]?.classList.remove("hc-dot-active");
      dots[next]?.classList.add("hc-dot-active");

      cur = next;

      // Clean up after animation
      setTimeout(() => {
        allSlides.forEach((s) => s.classList.remove("hc-enter", "hc-exit"));
        inSlide.classList.add("hc-active");
        locked = false;
      }, 780);
    }

    function advance() {
      go((cur + 1) % allSlides.length);
    }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(advance, SLIDE_INTERVAL);
    }

    // Dot clicks
    dots.forEach((d) =>
      d.addEventListener("click", () => {
        const i = Number(d.dataset.i);
        go(i);
        clearInterval(timer);
        startTimer();
      }),
    );

    // Pause on hover
    const root = document.getElementById("heroCarousel");
    root?.addEventListener("mouseenter", () => clearInterval(timer));
    root?.addEventListener("mouseleave", startTimer);

    // Trigger initial slide content animation
    const firstSlide = allSlides[0];
    if (firstSlide) {
      resetAnimItems(firstSlide);
      resetKenBurns(firstSlide);
    }

    // Start auto-play immediately
    startTimer();
  }

  // Run init — handle both pre- and post-DOMContentLoaded
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCarousel);
  } else {
    initCarousel();
  }
</script>
