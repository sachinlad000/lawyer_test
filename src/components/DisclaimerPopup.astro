---
/**
 * Disclaimer Popup Component
 * ==========================
 * Bar Council of India compliance popup.
 * Shows on first visit; acceptance stored in localStorage.
 */
---

<div id="disclaimer-popup" class="disclaimer-overlay" style="display:none;">
    <div class="disclaimer-modal">
        <div class="disclaimer-header">
            <div class="disclaimer-icon">⚖️</div>
            <h2>Disclaimer & Confirmation</h2>
        </div>

        <div class="disclaimer-body">
            <p class="disclaimer-intro">
                As per the rules of the Bar Council of India, advocates are not
                permitted to solicit work and advertise. By clicking on the <strong
                    >"I AGREE"</strong
                > button below, you acknowledge the following:
            </p>

            <ul class="disclaimer-list">
                <li>
                    There has been no advertisement, personal communication,
                    solicitation, invitation or inducement of any sort
                    whatsoever from Advocate Pradnya Pednekar to solicit any
                    work through this website.
                </li>
                <li>
                    You wish to gain more information about Advocate Pradnya
                    Pednekar for your own information and use.
                </li>
                <li>
                    The information about Advocate Pradnya Pednekar is provided
                    to you on your specific request and any information obtained
                    or materials downloaded from this website is completely at
                    your own volition and any transmission, receipt or use of
                    this site does not create any lawyer-client relationship;
                    and that
                </li>
                <li>
                    Advocate Pradnya Pednekar is not liable for any consequence
                    of any action taken by you relying on the material /
                    information provided on this website.
                </li>
                <li>
                    If you have any legal issues, you, in all cases, must seek
                    independent legal advice.
                </li>
            </ul>

            <div class="cookie-notice">
                <p>
                    🍪 We use cookies to enhance your experience. By continuing
                    to visit this website you agree to our use of cookies.
                </p>
            </div>
        </div>

        <div class="disclaimer-actions">
            <button id="disclaimer-agree" class="btn-agree">I AGREE</button>
            <button id="disclaimer-disagree" class="btn-disagree"
                >I DISAGREE</button
            >
        </div>
    </div>
</div>

<style>
    .disclaimer-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem;
        animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .disclaimer-modal {
        background: white;
        border-radius: 1rem;
        max-width: 620px;
        width: 100%;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
        animation: slideUp 0.4s ease;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .disclaimer-header {
        background: linear-gradient(135deg, #0a2463 0%, #1b3a7b 100%);
        color: white;
        padding: 1rem 1.5rem;
        text-align: center;
        border-radius: 1rem 1rem 0 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .disclaimer-header .disclaimer-icon {
        font-size: 1.75rem;
        margin-bottom: 0;
    }

    .disclaimer-header h2 {
        color: white;
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        font-family: "Playfair Display", serif;
    }

    .disclaimer-body {
        padding: 1.25rem 1.5rem 1rem;
    }

    .disclaimer-intro {
        font-size: 0.8125rem;
        line-height: 1.6;
        color: #374151;
        margin-bottom: 0.75rem;
    }

    .disclaimer-list {
        list-style: none;
        padding: 0;
        margin: 0 0 0.75rem;
    }

    .disclaimer-list li {
        position: relative;
        padding: 0.375rem 0 0.375rem 1.25rem;
        font-size: 0.8125rem;
        line-height: 1.5;
        color: #4b5563;
    }

    .disclaimer-list li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #d4af37;
        font-size: 0.875rem;
        font-weight: bold;
    }

    .cookie-notice {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 0.375rem;
        padding: 0.5rem 0.75rem;
    }

    .cookie-notice p {
        margin: 0;
        font-size: 0.75rem;
        color: #6b7280;
        line-height: 1.5;
    }

    .disclaimer-actions {
        display: flex;
        gap: 0.75rem;
        padding: 0.75rem 1.5rem 1.25rem;
        justify-content: center;
    }

    .btn-agree,
    .btn-disagree {
        padding: 0.75rem 2rem;
        border: none;
        border-radius: 0.5rem;
        font-size: 0.9375rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
        letter-spacing: 0.02em;
    }

    .btn-agree {
        background: linear-gradient(135deg, #0a2463 0%, #1b3a7b 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(10, 36, 99, 0.3);
    }

    .btn-agree:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(10, 36, 99, 0.4);
    }

    .btn-disagree {
        background: white;
        color: #6b7280;
        border: 2px solid #d1d5db;
    }

    .btn-disagree:hover {
        border-color: #ef4444;
        color: #ef4444;
    }

    @media (max-width: 640px) {
        .disclaimer-header {
            padding: 0.75rem 1rem;
        }

        .disclaimer-header .disclaimer-icon {
            font-size: 1.5rem;
        }

        .disclaimer-header h2 {
            font-size: 1.1rem;
        }

        .disclaimer-body {
            padding: 1rem;
        }

        .disclaimer-intro {
            font-size: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .disclaimer-list li {
            font-size: 0.75rem;
            padding: 0.25rem 0 0.25rem 1.25rem;
            line-height: 1.4;
        }

        .cookie-notice p {
            font-size: 0.6875rem;
        }

        .disclaimer-actions {
            flex-direction: column;
            padding: 0.5rem 1rem 1rem;
            gap: 0.5rem;
        }

        .btn-agree,
        .btn-disagree {
            width: 100%;
            text-align: center;
            padding: 0.625rem 1.5rem;
            font-size: 0.875rem;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const popup = document.getElementById("disclaimer-popup");
        const agreeBtn = document.getElementById("disclaimer-agree");
        const disagreeBtn = document.getElementById("disclaimer-disagree");

        // Check if user already accepted
        if (!localStorage.getItem("disclaimer_accepted")) {
            if (popup) {
                popup.style.display = "flex";
                document.body.style.overflow = "hidden";
            }
        }

        agreeBtn?.addEventListener("click", () => {
            localStorage.setItem("disclaimer_accepted", "true");
            if (popup) {
                popup.style.display = "none";
                document.body.style.overflow = "";
            }
        });

        disagreeBtn?.addEventListener("click", () => {
            window.location.href = "https://www.google.com";
        });
    });
</script>
