---
/**
 * Header Component
 * ================
 * Responsive header with transparent → solid navbar on scroll.
 * Navbar overlays the hero section (transparent) and becomes solid on scroll.
 *
 * CONFIGURATION: Edit src/config/site.config.ts for navigation and contact info.
 */

import { Scale, Phone, Menu, X, ChevronDown } from "@lucide/astro";
import { siteConfig } from "../config/site.config";

// Navigation comes from central config
const navItems = siteConfig.navigation.main;

// Contact info from central config
const phone = siteConfig.contact.phone.display;
const phoneClean = siteConfig.contact.phone.primary.replace(/[^0-9+]/g, "");

// Branding from config
const advocateName = siteConfig.advocate.name;
const firmTagline = "(Kulkarni)";
const barInfo = `Bar Council Registered | ${siteConfig.advocate.experience} Years of Experience`;
---

<!-- Header Top Bar — scrolls away naturally, not fixed --><!-- <div class="header-top">
  <div class="container">
    <div class="header-top-content">
      <span class="header-top-text">
        <Scale size={16} />
        {barInfo}
      </span>
      <a href={`tel:${phoneClean}`} class="header-top-phone">
        <Phone size={16} />
        {phone}
      </a>
    </div>
  </div>
</div> --><!-- Fixed Navbar — transparent over hero, solid on scroll -->
<header class="header header--transparent" id="siteHeader">
  <nav class="navbar">
    <div class="container">
      <div class="navbar-content">
        <!-- Logo -->
        <a href="/" class="navbar-logo">
          <Scale size={36} class="logo-icon" />
          <div class="logo-text">
            <span class="logo-name">{advocateName}</span>
            <span class="logo-tagline">{firmTagline}</span>
          </div>
        </a>

        <!-- Desktop Navigation -->
        <ul class="nav-menu hide-mobile">
          {
            navItems.map((item) => (
              <li class={item.children ? "nav-item has-dropdown" : "nav-item"}>
                <a href={item.href} class="nav-link">
                  {item.label}
                  {item.children && (
                    <ChevronDown size={16} class="dropdown-icon" />
                  )}
                </a>
                {item.children && (
                  <ul class="dropdown-menu">
                    {item.children.map((subItem) => (
                      <li>
                        <a href={subItem.href} class="dropdown-link">
                          {subItem.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))
          }
        </ul>

        <!-- CTA Button (Desktop) -->
        <!-- <a href="/contact" class="btn btn-accent hide-mobile">
          Book Appointment
        </a> -->

        <!-- Mobile Menu Toggle -->
        <button
          class="mobile-menu-toggle hide-desktop"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <Menu size={28} class="menu-icon" />
          <X size={28} class="close-icon" />
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="mobile-nav hide-desktop">
      <div class="container">
        <ul class="mobile-nav-menu">
          {
            navItems.map((item) => (
              <li class="mobile-nav-item">
                <a href={item.href} class="mobile-nav-link">
                  {item.label}
                </a>
                {item.children && (
                  <ul class="mobile-dropdown">
                    {item.children.map((subItem) => (
                      <li>
                        <a href={subItem.href} class="mobile-dropdown-link">
                          {subItem.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))
          }
        </ul>
        <a href="/contact" class="btn btn-accent btn-lg mobile-cta">
          Book Appointment
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  /* ============================================
     HEADER TOP BAR — scrolls naturally
     ============================================ */
  .header-top {
    background: var(--color-primary-900);
    color: white;
    padding: 0.5rem 0;
    font-size: 0.875rem;
    position: relative;
    z-index: 101;
  }

  .header-top-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .header-top-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header-top-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent-500);
    font-weight: 600;
  }

  .header-top-phone:hover {
    color: var(--color-accent-400);
  }

  /* ============================================
     FIXED NAVBAR — transparent/solid states
     ============================================ */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition:
      background-color 0.35s ease,
      box-shadow 0.35s ease,
      backdrop-filter 0.35s ease;
    will-change: background-color, box-shadow;
  }

  .navbar {
    padding: 1rem 0;
    transition: padding 0.35s ease;
  }

  .navbar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ---- Transparent State (over hero) ---- */
  .header--transparent {
    background: transparent;
    box-shadow: none;
  }

  .header--transparent .navbar-logo {
    color: white;
  }

  .header--transparent .logo-icon {
    color: var(--color-accent-500);
  }

  .header--transparent .logo-tagline {
    color: rgba(255, 255, 255, 0.8);
  }

  .header--transparent .nav-link {
    color: rgba(255, 255, 255, 0.9);
  }

  .header--transparent .nav-link:hover {
    color: white;
  }

  .header--transparent .nav-link::after {
    background: var(--color-accent-500);
  }

  .header--transparent .navbar-cta {
    background: var(--color-accent-500);
    color: var(--color-primary-900);
    border-color: var(--color-accent-500);
  }

  .header--transparent .navbar-cta:hover {
    background: var(--color-accent-400);
    color: var(--color-primary-900);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.35);
  }

  .header--transparent .mobile-menu-toggle {
    color: white;
  }

  .header--transparent .dropdown-menu {
    background: rgba(10, 36, 99, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header--transparent .dropdown-link {
    color: rgba(255, 255, 255, 0.85);
  }

  .header--transparent .dropdown-link:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  /* ---- Solid State (scrolled past hero) ---- */
  .header:not(.header--transparent) {
    background: white;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
  }

  .header:not(.header--transparent) .navbar {
    padding: 0.75rem 0;
  }

  .header:not(.header--transparent) .navbar-logo {
    color: var(--color-primary-900);
  }

  .header:not(.header--transparent) .logo-icon {
    color: var(--color-accent-500);
  }

  .header:not(.header--transparent) .logo-tagline {
    color: var(--color-accent-950);
  }

  .header:not(.header--transparent) .nav-link {
    color: var(--color-neutral-700);
  }

  .header:not(.header--transparent) .nav-link:hover {
    color: var(--color-primary-900);
  }

  .header:not(.header--transparent) .nav-link::after {
    background: var(--color-primary-900);
  }

  .header:not(.header--transparent) .mobile-menu-toggle {
    color: var(--color-primary-900);
  }

  /* ============================================
     LOGO — enlarged, responsive
     ============================================ */
  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: color 0.35s ease;
  }

  .navbar-logo:hover {
    opacity: 0.9;
  }

  .logo-icon {
    transition: color 0.35s ease;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-name {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 2.5vw, 1.85rem);
    font-weight: 700;
    transition: color 0.35s ease;
  }

  .logo-tagline {
    font-size: clamp(0.75rem, 1.5vw, 1rem);
    font-weight: 600;
    transition: color 0.35s ease;
  }

  /* ============================================
     DESKTOP NAV — with underline hover animation
     ============================================ */
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 1rem;
    font-weight: 500;
    position: relative;
    transition: color 0.3s ease;
  }

  /* Underline animation on hover */
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 1rem;
    right: 1rem;
    height: 2px;
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s ease;
    will-change: transform;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .dropdown-icon {
    transition: transform var(--transition-fast);
  }

  .has-dropdown:hover .dropdown-icon {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background: white;
    border-radius: 0.5rem;
    box-shadow: var(--shadow-lg);
    list-style: none;
    padding: 0.5rem 0;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all var(--transition-fast);
  }

  .has-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-link {
    display: block;
    padding: 0.75rem 1.25rem;
    color: var(--color-neutral-700);
    transition: all var(--transition-fast);
  }

  .dropdown-link:hover {
    background: var(--color-neutral-100);
    color: var(--color-primary-900);
  }

  /* ============================================
     MOBILE MENU
     ============================================ */
  .mobile-menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: color 0.35s ease;
  }

  .mobile-menu-toggle .close-icon {
    display: none;
  }

  .mobile-menu-toggle.active .menu-icon {
    display: none;
  }

  .mobile-menu-toggle.active .close-icon {
    display: block;
  }

  .mobile-nav {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border-top: 1px solid var(--color-neutral-200);
    box-shadow: var(--shadow-lg);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .mobile-nav.active {
    max-height: 80vh;
    overflow-y: auto;
  }

  .mobile-nav-menu {
    list-style: none;
    padding: 1rem 0;
    margin: 0;
  }

  .mobile-nav-link {
    display: block;
    padding: 1rem 0;
    color: var(--color-neutral-800);
    font-size: 1.125rem;
    font-weight: 500;
    border-bottom: 1px solid var(--color-neutral-100);
  }

  .mobile-dropdown {
    list-style: none;
    padding: 0;
    margin: 0;
    padding-left: 1rem;
  }

  .mobile-dropdown-link {
    display: block;
    padding: 0.75rem 0;
    color: var(--color-neutral-600);
    font-size: 1rem;
  }

  .mobile-cta {
    width: 100%;
    margin: 1rem 0 2rem;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .header-top-text {
      font-size: 0.75rem;
    }

    .logo-name {
      font-size: 1.2rem;
    }

    .logo-tagline {
      font-size: 1rem;
    }
  }
</style>

<script>
  // Mobile menu toggle
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.querySelector(".mobile-menu-toggle");
    const mobileNav = document.querySelector(".mobile-nav");

    if (toggle && mobileNav) {
      toggle.addEventListener("click", () => {
        toggle.classList.toggle("active");
        mobileNav.classList.toggle("active");
        const isExpanded = toggle.classList.contains("active");
        toggle.setAttribute("aria-expanded", String(isExpanded));
      });

      // Close menu when clicking a link
      mobileNav.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          toggle.classList.remove("active");
          mobileNav.classList.remove("active");
          toggle.setAttribute("aria-expanded", "false");
        });
      });
    }

    // ====================================
    // Navbar transparent → solid on scroll
    // ====================================
    const header = document.getElementById("siteHeader");
    const heroSection = document.querySelector(".hero-carousel");

    if (header && heroSection) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Hero is visible → transparent navbar
              header.classList.add("header--transparent");
            } else {
              // Hero is out of view → solid navbar
              header.classList.remove("header--transparent");
            }
          });
        },
        {
          threshold: 0.05,
          rootMargin: "-80px 0px 0px 0px",
        },
      );

      observer.observe(heroSection);
    } else if (header) {
      // No hero section on this page → always solid
      header.classList.remove("header--transparent");
    }
  });
</script>
