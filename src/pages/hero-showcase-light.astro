---
/**
 * Hero Showcase Light Page
 * =======================
 * Displays all 5 LIGHT versions of the hero section variants.
 */
import Layout from "../layouts/Layout.astro";
import HeroVariant1Light from "../components/sections/HeroVariant1Light.astro";
import HeroVariant2Light from "../components/sections/HeroVariant2Light.astro";
import HeroVariant3Light from "../components/sections/HeroVariant3Light.astro";
import HeroVariant4Light from "../components/sections/HeroVariant4Light.astro";
import HeroVariant5Light from "../components/sections/HeroVariant5Light.astro";
---

<Layout
  title="Hero Section Showcase — Light Mode Variants"
  description="Preview 5 unique light theme hero section designs with enhanced animations."
>
  <nav class="showcase-nav" aria-label="Hero variant navigation">
    <div class="showcase-nav-inner">
      <span class="showcase-nav-label">Light Variants:</span>
      <a href="#hero-v1-light" class="showcase-nav-link">1 — Minimal</a>
      <a href="#hero-v2-light" class="showcase-nav-link">2 — Bold</a>
      <a href="#hero-v3-light" class="showcase-nav-link">3 — Glass</a>
      <a href="#hero-v4-light" class="showcase-nav-link">4 — Luxury</a>
      <a href="#hero-v5-light" class="showcase-nav-link">5 — Futuristic</a>
      
      <div style="margin-left: auto; display:flex; gap: 8px;">
        <a href="/hero-showcase" class="showcase-nav-link" style="border-color: #d4af37; color: #d4af37;">Switch to Dark Versions</a>
      </div>
    </div>
  </nav>

  <div class="showcase-section">
    <div class="showcase-label">
      <span class="showcase-num">01</span>
      <span class="showcase-name">Light Minimal</span>
    </div>
    <HeroVariant1Light />
  </div>

  <div class="showcase-section">
    <div class="showcase-label">
      <span class="showcase-num">02</span>
      <span class="showcase-name">Light Bold Authority</span>
    </div>
    <HeroVariant2Light />
  </div>

  <div class="showcase-section">
    <div class="showcase-label">
      <span class="showcase-num">03</span>
      <span class="showcase-name">Light Glassmorphic</span>
    </div>
    <HeroVariant3Light />
  </div>

  <div class="showcase-section">
    <div class="showcase-label">
      <span class="showcase-num">04</span>
      <span class="showcase-name">Light Luxury</span>
    </div>
    <HeroVariant4Light />
  </div>

  <div class="showcase-section">
    <div class="showcase-label">
      <span class="showcase-num">05</span>
      <span class="showcase-name">Light Futuristic Auto-Gravity</span>
    </div>
    <HeroVariant5Light />
  </div>
</Layout>

<style>
  /* Sticky navigation */
  .showcase-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(10, 36, 99, 0.1);
    padding: 0;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  .showcase-nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .showcase-nav-inner::-webkit-scrollbar { display: none; }

  .showcase-nav-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #1e293b;
    margin-right: 8px;
    flex-shrink: 0;
  }

  .showcase-nav-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #475569;
    text-decoration: none;
    border: 1px solid rgba(10, 36, 99, 0.1);
    border-radius: 8px;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .showcase-nav-link:hover {
    border-color: #0a2463;
    color: #0a2463;
    background: rgba(10, 36, 99, 0.05);
  }

  /* Section labels */
  .showcase-section {
    position: relative;
  }

  .showcase-label {
    position: absolute;
    top: 70px;
    left: 30px;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 18px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(10, 36, 99, 0.1);
    border-radius: 12px;
    pointer-events: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .showcase-num {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #b45309;
    line-height: 1;
  }

  .showcase-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: #0a2463;
  }
</style>
